// --- 5. MODULO GESTIONE CLIENTI ---
function ClientsModule({ user, appId, navigateToModule }) {
    const [clients, setClients] = useState([]);
    const [loading, setLoading] = useState(true);
    const [searchTerm, setSearchTerm] = useState('');
    const [showModal, setShowModal] = useState(false);
    const [dialog, setDialog] = useState(null);
    const [isSaving, setIsSaving] = useState(false);
    const initialClientState = { company: '', name: '', phone: '', email: '', address: '', type: 'Residenziale', status: 'Attivo', notes: '', convertedAt: new Date().toISOString().split('T')[0], linkDrive: '', linkGoogleEarth: '', linkGoogleMaps: '', linkSitoWeb: '' };
    const [currentClient, setCurrentClient] = useState(initialClientState);

    useEffect(() => {
        if (!user || !db) return;
        const unsub = onSnapshot(collection(db, 'artifacts', appId, 'users', user.uid, 'clients'), (snap) => {
            const data = snap.docs.map(d => ({id: d.id, ...d.data()}));
            data.sort((a,b) => new Date(b.convertedAt || 0).getTime() - new Date(a.convertedAt || 0).getTime());
            setClients(data); setLoading(false);
        });
        return () => unsub();
    }, [user, appId]);

    const handleSaveClient = async () => {
        if (!currentClient.company) { setDialog({ title: "Attenzione", message: "Nome Azienda/Cliente obbligatorio", type: 'alert', onConfirm: () => setDialog(null) }); return; }
        setIsSaving(true);
        try {
            const cleanedClient = Object.fromEntries(Object.entries(currentClient).filter(([_, v]) => v !== undefined));
            if (cleanedClient.convertedAt && cleanedClient.convertedAt.length === 10) { cleanedClient.convertedAt = new Date(cleanedClient.convertedAt).toISOString(); }
            if (currentClient.id) {
                const { id, ...data } = cleanedClient;
                await updateDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'clients', id), data);
            } else {
                await addDoc(collection(db, 'artifacts', appId, 'users', user.uid, 'clients'), { ...cleanedClient, createdAt: new Date().toISOString() });
            }
            setShowModal(false); setCurrentClient(initialClientState);
        } catch (err) { setDialog({ title: "Errore", message: "Impossibile salvare", type: 'alert', onConfirm: () => setDialog(null) }); } finally { setIsSaving(false); }
    };

    const handleSendToPipeline = (client) => {
        setDialog({
            title: "Invia a Pipeline", message: `Vuoi inviare "${client.company}" in Pipeline come Up-Selling?`, type: 'confirm',
            onConfirm: async () => {
                setDialog(null);
                try {
                    const leadData = { company: client.company || '', name: client.name || '', phone: client.phone || '', email: client.email || '', address: client.address || '', type: client.type || 'Residenziale', stage: 'Da Contattare', source: 'Anagrafica', expectedValue: '', notes: client.notes ? `[Da Clienti]: ${client.notes}` : '', createdAt: new Date().toISOString() };
                    await addDoc(collection(db, 'artifacts', appId, 'users', user.uid, 'leads'), leadData);
                    setDialog({ title: "Successo", message: "Opportunità creata in Pipeline!", type: 'confirm', onConfirm: () => { setDialog(null); navigateToModule('pipeline'); }, onCancel: () => setDialog(null) });
                } catch (err) { setDialog({ title: "Errore", message: "Errore durante la creazione.", type: 'alert', onConfirm: () => setDialog(null) }); }
            }, onCancel: () => setDialog(null)
        });
    };

    const handleDelete = async (id, company) => {
        setDialog({ title: "Elimina", message: `Eliminare "${company}"? L'azione è irreversibile.`, type: 'confirm', onConfirm: async () => { setDialog(null); await deleteDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'clients', id)); }, onCancel: () => setDialog(null) });
    };

    const filtered = clients.filter(c => (c.company||'').toLowerCase().includes(searchTerm.toLowerCase()) || (c.name||'').toLowerCase().includes(searchTerm.toLowerCase()));

    if (loading) return <div className="p-10 text-center"><Loader2 className="animate-spin mx-auto text-[#9a0002]"/></div>;

    return (
        <div className="h-full flex flex-col animate-in fade-in duration-300 max-w-7xl mx-auto relative">
            {dialog && (<div className="fixed inset-0 bg-black/50 z-[100] flex items-center justify-center p-4"><div className="bg-white rounded-xl p-6 max-w-sm w-full shadow-2xl"><h3 className="font-bold text-lg mb-2">{dialog.title}</h3><p className="text-slate-600 mb-6">{dialog.message}</p><div className="flex justify-end gap-3">{dialog.type === 'confirm' && (<button onClick={dialog.onCancel} className="px-4 py-2 rounded-lg font-medium text-slate-600 hover:bg-slate-100 transition">Annulla</button>)}<button onClick={dialog.onConfirm} className="px-4 py-2 rounded-lg font-bold bg-[#9a0002] text-white hover:bg-[#7a0001] transition">OK</button></div></div></div>)}

            <div className="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
                <div className="flex items-center gap-3">
                    <div className="bg-[#059669]/10 text-[#059669] p-2.5 rounded-xl border border-[#059669]/20"><Users size={24} /></div>
                    <h2 className="text-2xl font-extrabold text-slate-800 tracking-tight">Anagrafica Clienti Attivi</h2>
                </div>
                <div className="flex items-center gap-3 w-full md:w-auto">
                    <div className="relative w-full md:w-64">
                        <Search className="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400" size={18} />
                        <input type="text" placeholder="Cerca cliente..." value={searchTerm} onChange={e => setSearchTerm(e.target.value)} className="w-full pl-10 pr-4 py-2.5 bg-white border border-slate-200 shadow-sm rounded-xl focus:ring-2 focus:ring-[#059669] outline-none transition" />
                    </div>
                    <button onClick={() => { setCurrentClient(initialClientState); setShowModal(true); }} className="bg-[#059669] text-white px-4 py-2.5 rounded-xl font-bold shadow-md hover:bg-[#047857] flex items-center gap-2 transition whitespace-nowrap">
                        <Plus size={18}/> Nuovo Cliente
                    </button>
                </div>
            </div>
            
            {filtered.length === 0 ? (
                <div className="bg-white p-12 rounded-xl shadow-sm border border-dashed border-slate-300 text-center text-slate-500">
                    <Users size={48} className="text-slate-300 mx-auto mb-4" />
                    <p className="text-lg font-medium">Nessun cliente in anagrafica.</p>
                </div>
            ) : (
                <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 pb-10 content-start overflow-y-auto custom-scrollbar">
                    {filtered.map(c => (
                        <div key={c.id} className="bg-white rounded-xl shadow-sm border border-slate-200 hover:shadow-md hover:border-[#059669] transition-all flex flex-col relative group overflow-hidden">
                            <div className={`absolute left-0 top-0 bottom-0 w-1.5 ${c.type === 'Azienda' ? 'bg-indigo-500' : c.type === 'Residenziale' ? 'bg-[#9a0002]' : c.type === 'ASD' ? 'bg-yellow-500' : 'bg-[#059669]'}`}></div>
                            <div className="p-5 pl-6 flex flex-col h-full">
                                <div className="flex items-start justify-between gap-3 mb-4">
                                    <div className="overflow-hidden flex-1">
                                        <h4 className="font-extrabold text-slate-800 text-[16px] leading-tight truncate pr-2" title={c.company}>{c.company}</h4>
                                        <span className="text-[9px] font-bold text-slate-500 uppercase bg-slate-100 px-1.5 py-0.5 rounded mt-1 inline-block">{c.type || 'Cliente'}</span>
                                    </div>
                                    <button onClick={() => handleSendToPipeline(c)} className="text-purple-600 bg-purple-50 hover:bg-purple-600 hover:text-white p-1.5 rounded-lg transition-all shadow-sm border border-purple-100 flex-shrink-0" title="Genera Up-Selling in Pipeline">
                                        <Target size={16}/>
                                    </button>
                                </div>
                                <div className="flex flex-col gap-2 flex-1">
                                    <div className="flex items-center gap-2 text-slate-700 bg-slate-50 px-3 py-2 rounded-lg border border-slate-100"><UserCircle size={14} className="text-slate-400"/><span className="text-[12px] font-bold truncate">{c.name || 'Nessun referente'}</span></div>
                                    <div className="flex items-center gap-2 text-[11px] text-slate-600 px-1"><Phone size={12} className="text-slate-400"/> <span className="font-medium truncate">{c.phone || 'N/D'}</span></div>
                                    <div className="flex items-center gap-2 text-[11px] text-slate-600 px-1"><Mail size={12} className="text-slate-400"/> <span className="font-medium truncate">{c.email || 'N/D'}</span></div>
                                </div>
                                <div className="mt-5 pt-3 border-t border-slate-100 flex justify-between items-center">
                                    <span className="text-[10px] font-bold text-slate-400 uppercase flex items-center gap-1.5"><Calendar size={12}/> {c.convertedAt ? new Date(c.convertedAt).toLocaleDateString('it-IT') : '-'}</span>
                                    <div className="flex items-center gap-1">
                                        <button onClick={() => { setCurrentClient({...c, convertedAt: c.convertedAt ? c.convertedAt.split('T')[0] : ''}); setShowModal(true); }} className="p-1.5 text-slate-400 hover:text-blue-600 bg-slate-50 hover:bg-blue-50 rounded-md transition"><Edit size={14}/></button>
                                        <button onClick={() => handleDelete(c.id, c.company)} className="p-1.5 text-slate-400 hover:text-red-600 bg-slate-50 hover:bg-red-50 rounded-md transition"><Trash2 size={14}/></button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            )}

            {showModal && (
                <div className="fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4 backdrop-blur-sm">
                    <div className="bg-white rounded-xl w-full max-w-2xl shadow-2xl overflow-hidden animate-in fade-in zoom-in duration-200">
                        <div className="bg-[#059669] p-4 flex justify-between items-center text-white">
                            <h3 className="font-bold text-lg flex items-center gap-2"><UserCheck size={18}/> {currentClient.id ? 'Modifica Anagrafica' : 'Nuovo Cliente Acquisito'}</h3>
                            <button onClick={() => { setShowModal(false); setCurrentClient(initialClientState); }} className="hover:bg-white/20 p-1.5 rounded-lg transition"><X size={20}/></button>
                        </div>
                        <div className="p-6 max-h-[75vh] overflow-y-auto custom-scrollbar">
                            <div className="space-y-4">
                                <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <Input label="Nome Azienda / Cliente *" value={currentClient.company || ''} onChange={v => setCurrentClient({...currentClient, company: v})} placeholder="Es. Giuseppe Bianchi S.r.l." />
                                    <Select label="Tipologia" value={currentClient.type || ''} onChange={v => setCurrentClient({...currentClient, type: v})} options={['Residenziale', 'Azienda', 'ASD']} />
                                </div>
                                <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <Input label="Referente / Titolare" value={currentClient.name || ''} onChange={v => setCurrentClient({...currentClient, name: v})} placeholder="Nome e Cognome" />
                                    <Input label="Telefono" value={currentClient.phone || ''} onChange={v => setCurrentClient({...currentClient, phone: v})} placeholder="Es. 333..." />
                                </div>
                                <Textarea label="Note Storiche / Up-selling" value={currentClient.notes || ''} onChange={v => setCurrentClient({...currentClient, notes: v})} placeholder="Es. Impianto FV installato nel 2021. Potenziale per Accumulo..." />
                            </div>
                        </div>
                        <div className="bg-slate-50 p-4 border-t border-slate-200 flex justify-end gap-3">
                            <button onClick={() => { setShowModal(false); setCurrentClient(initialClientState); }} className="px-4 py-2 font-medium text-slate-600 hover:bg-slate-200 rounded-lg transition">Annulla</button>
                            <button onClick={handleSaveClient} disabled={isSaving} className="bg-[#059669] hover:bg-[#047857] text-white px-5 py-2 rounded-lg font-bold shadow-md flex items-center gap-2 transition disabled:opacity-50">
                                {isSaving ? <Loader2 size={16} className="animate-spin" /> : <Save size={16}/>} {currentClient.id ? 'Salva Modifiche' : 'Crea Cliente'}
                            </button>
                        </div>
                    </div>
                </div>
            )}
        </div>
    );
}

// --- 6. MODULO ARCHIVIO FOTO ---
function GalleryModule({ user, appId }) {
    const [photos, setPhotos] = useState([]);
    const [showModal, setShowModal] = useState(false);
    const [newPhoto, setNewPhoto] = useState({ title: '', url: '' });

    useEffect(() => {
        if (!user) return;
        return onSnapshot(collection(db, 'artifacts', appId, 'users', user.uid, 'gallery'), (snap) => {
            setPhotos(snap.docs.map(d => ({id: d.id, ...d.data()})));
        });
    }, [user, appId]);

    const handleSave = async () => {
        if (!newPhoto.url) return;
        await addDoc(collection(db, 'artifacts', appId, 'users', user.uid, 'gallery'), { ...newPhoto, createdAt: new Date().toISOString() });
        setShowModal(false); setNewPhoto({ title: '', url: '' });
    };

    const deletePhoto = async (id) => await deleteDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'gallery', id));

    return (
        <div className="h-full flex flex-col space-y-6 animate-in fade-in duration-300">
            <div className="flex justify-between items-center mb-2">
                <div className="flex items-center gap-3">
                    <div className="bg-teal-100 text-teal-600 p-2.5 rounded-xl border border-teal-200"><Camera size={24}/></div>
                    <h2 className="text-2xl font-extrabold text-slate-800 tracking-tight">Archivio Foto Rilievi</h2>
                </div>
                <button onClick={() => setShowModal(true)} className="bg-teal-600 text-white px-4 py-2.5 rounded-xl font-bold shadow-md hover:bg-teal-700 flex items-center gap-2 transition"><Plus size={18}/> Nuovo Link Foto</button>
            </div>

            <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 pb-10 custom-scrollbar overflow-y-auto">
                {photos.map(p => (
                    <div key={p.id} className="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden group relative flex flex-col hover:shadow-md transition">
                        <div className="h-48 bg-slate-100 flex items-center justify-center overflow-hidden relative">
                            {(p.url && typeof p.url === 'string' && p.url.match(/\.(jpeg|jpg|gif|png)$/i)) ? 
                                <img src={p.url} alt={p.title || 'Foto'} className="w-full h-full object-cover group-hover:scale-105 transition duration-500" onError={(e) => {e.target.style.display='none'; if(e.target.nextSibling) e.target.nextSibling.style.display='flex';}} /> 
                                : <div className="text-slate-400 flex flex-col items-center gap-2"><Link size={32}/><span className="text-xs font-bold uppercase tracking-wider">Link Cloud</span></div>
                            }
                        </div>
                        <div className="p-4 bg-white flex justify-between items-center relative z-10 border-t border-slate-100">
                            <h4 className="font-extrabold text-sm text-slate-800 truncate pr-2" title={p.title}>{p.title || 'Foto Rilievo'}</h4>
                            <div className="flex gap-1">
                                {p.url && <button onClick={() => window.open(p.url.startsWith('http') ? p.url : `https://${p.url}`, '_blank')} className="p-2 text-blue-600 hover:bg-blue-50 rounded-lg transition border border-transparent hover:border-blue-100" title="Apri Link"><ExternalLink size={16}/></button>}
                                <button onClick={() => deletePhoto(p.id)} className="p-2 text-red-600 hover:bg-red-50 rounded-lg transition border border-transparent hover:border-red-100" title="Elimina"><Trash2 size={16}/></button>
                            </div>
                        </div>
                    </div>
                ))}
                {photos.length === 0 && <div className="col-span-full p-12 text-center text-slate-500 border-2 border-dashed border-slate-300 rounded-2xl"><Camera size={40} className="mx-auto mb-3 text-slate-300"/>Nessun link salvato in archivio.</div>}
            </div>

            {showModal && (
