    const categories = [
        { name: 'Tool Tecnici', color: 'bg-orange-50 text-orange-700 border-orange-200', cardBorder: 'border-orange-300 hover:border-orange-500', btnClass: 'text-orange-700 hover:bg-orange-100', icon: <Calculator size={20}/> },
        { name: 'Cloud & Drive', color: 'bg-blue-50 text-blue-700 border-blue-200', cardBorder: 'border-blue-300 hover:border-blue-500', btnClass: 'text-blue-700 hover:bg-blue-100', icon: <Folder size={20}/> },
        { name: 'Fornitori', color: 'bg-green-50 text-green-700 border-green-200', cardBorder: 'border-green-300 hover:border-green-500', btnClass: 'text-green-700 hover:bg-green-100', icon: <Factory size={20}/> },
        { name: 'Amministrazione', color: 'bg-purple-50 text-purple-700 border-purple-200', cardBorder: 'border-purple-300 hover:border-purple-500', btnClass: 'text-purple-700 hover:bg-purple-100', icon: <FileText size={20}/> },
        { name: 'ChatGPT', color: 'bg-emerald-50 text-emerald-700 border-emerald-200', cardBorder: 'border-emerald-300 hover:border-emerald-500', btnClass: 'text-emerald-700 hover:bg-emerald-100', icon: <Sparkles size={20}/> },
        { name: 'Gemini', color: 'bg-indigo-50 text-indigo-700 border-indigo-200', cardBorder: 'border-indigo-300 hover:border-indigo-500', btnClass: 'text-indigo-700 hover:bg-indigo-100', icon: <Sparkles size={20}/> },
        { name: 'Perplexity', color: 'bg-cyan-50 text-cyan-700 border-cyan-200', cardBorder: 'border-cyan-300 hover:border-cyan-500', btnClass: 'text-cyan-700 hover:bg-cyan-100', icon: <Search size={20}/> },
        { name: 'NotebookLM', color: 'bg-violet-50 text-violet-700 border-violet-200', cardBorder: 'border-violet-300 hover:border-violet-500', btnClass: 'text-violet-700 hover:bg-violet-100', icon: <FileText size={20}/> },
        { name: 'Altro', color: 'bg-slate-50 text-slate-700 border-slate-200', cardBorder: 'border-slate-300 hover:border-slate-500', btnClass: 'text-slate-700 hover:bg-slate-100', icon: <Globe size={20}/> }
    ];

    const tagColors = [
        { id: 'slate', pickerBg: 'bg-slate-400', class: 'bg-slate-100 text-slate-700 border-slate-200' },
        { id: 'red', pickerBg: 'bg-red-400', class: 'bg-red-50 text-red-700 border-red-200' },
        { id: 'green', pickerBg: 'bg-green-400', class: 'bg-green-50 text-green-700 border-green-200' },
        { id: 'blue', pickerBg: 'bg-blue-400', class: 'bg-blue-50 text-blue-700 border-blue-200' },
        { id: 'yellow', pickerBg: 'bg-yellow-400', class: 'bg-yellow-50 text-yellow-700 border-yellow-200' },
        { id: 'purple', pickerBg: 'bg-purple-400', class: 'bg-purple-50 text-purple-700 border-purple-200' }
    ];

    useEffect(() => {
        if (!user || !db) return;
        const unsubscribe = onSnapshot(collection(db, 'artifacts', appId, 'users', user.uid, 'custom_links'), (snapshot) => {
            const data = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
            data.sort((a, b) => (a.title || '').localeCompare(b.title || ''));
            setLinks(data);
            setLoading(false);
        });
        return () => unsubscribe();
    }, [user, appId]);

    const handleCreateNew = () => { 
        setEditingLink({ ...initialLinkState }); 
        setTagInput('');
        setTagColor(tagColors[0].class);
        setShowModal(true); 
    };

    const handleAddTag = (e) => {
        if (e) e.preventDefault();
        if (!tagInput.trim()) return;
        setEditingLink(prev => ({
            ...prev,
            tags: [...(prev.tags || []), { text: tagInput.trim(), colorClass: tagColor }]
        }));
        setTagInput('');
    };

    const handleRemoveTag = (index) => {
        setEditingLink(prev => ({
            ...prev,
            tags: (prev.tags || []).filter((_, i) => i !== index)
        }));
    };

    const handleDelete = async (id, title) => {
        setDialog({ title: "Elimina Link", message: `Sei sicuro di voler eliminare "${title}"?`, type: 'confirm', onConfirm: async () => { setDialog(null); await deleteDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'custom_links', id)); }, onCancel: () => setDialog(null) });
    };

    const handleSaveLink = async () => {
        if (!editingLink.title || !editingLink.url) { setDialog({ title: "Attenzione", message: "Titolo e URL sono obbligatori.", type: 'alert', onConfirm: () => setDialog(null) }); return; }
        setIsSaving(true);
        try {
            if (editingLink.id) {
                const { id, ...data } = editingLink;
                await updateDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'custom_links', id), data);
            } else {
                await addDoc(collection(db, 'artifacts', appId, 'users', user.uid, 'custom_links'), { ...editingLink, createdAt: new Date().toISOString() });
            }
            setShowModal(false); setEditingLink(null);
        } catch (error) { setDialog({ title: "Errore", message: "Errore salvataggio.", type: 'alert', onConfirm: () => setDialog(null) }); } finally { setIsSaving(false); }
    };

    const filteredLinks = links.filter(l => {
        const term = searchTerm.toLowerCase();
        const matchesText = String(l.title || '').toLowerCase().includes(term) || String(l.description || '').toLowerCase().includes(term) || String(l.category || '').toLowerCase().includes(term);
        const matchesTags = (l.tags || []).some(t => String(t.text).toLowerCase().includes(term));
        return matchesText || matchesTags;
    });

    const groupedLinks = categories.reduce((acc, cat) => {
        const catLinks = filteredLinks.filter(l => l.category === cat.name);
        if (catLinks.length > 0) acc.push({ ...cat, links: catLinks });
        return acc;
    }, []);

    const knownCategoryNames = categories.map(c => c.name);
    const orphanLinks = filteredLinks.filter(l => !knownCategoryNames.includes(l.category));
    if (orphanLinks.length > 0) {
        const altroCat = groupedLinks.find(g => g.name === 'Altro');
        if (altroCat) altroCat.links.push(...orphanLinks);
        else groupedLinks.push({ ...categories.find(c => c.name === 'Altro'), links: orphanLinks });
    }

    if (loading) return <div className="p-10 text-center"><Loader2 className="animate-spin mx-auto text-[#9a0002]"/></div>;

    return (
        <div className="max-w-7xl mx-auto h-full flex flex-col space-y-6 animate-in fade-in duration-300">
            {dialog && (<div className="fixed inset-0 bg-black/50 z-[100] flex items-center justify-center p-4"><div className="bg-white rounded-xl p-6 max-w-sm w-full shadow-2xl"><h3 className="font-bold text-lg mb-2">{dialog.title}</h3><p className="text-slate-600 mb-6">{dialog.message}</p><div className="flex justify-end gap-3">{dialog.type === 'confirm' && (<button onClick={dialog.onCancel} className="px-4 py-2 rounded-lg font-medium text-slate-600 hover:bg-slate-100">Annulla</button>)}<button onClick={dialog.onConfirm} className="px-4 py-2 rounded-lg font-bold bg-[#9a0002] text-white hover:bg-[#7a0001]">OK</button></div></div></div>)}
            
            <div className="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-2">
                <div className="flex items-center gap-3">
                    <div className="bg-blue-100 text-blue-600 p-2.5 rounded-xl border border-blue-200"><Link size={24} /></div>
                    <h2 className="text-2xl font-extrabold text-slate-800 tracking-tight">Gestione Link ({filteredLinks.length})</h2>
                </div>
                <div className="flex items-center gap-3 w-full md:w-auto">
                    <div className="hidden md:flex items-center bg-slate-200/50 p-1 rounded-lg border border-slate-200">
                        <button onClick={() => setViewMode('card')} className={`p-1.5 rounded-md transition-all ${viewMode === 'card' ? 'bg-white shadow-sm text-blue-600' : 'text-slate-400 hover:text-slate-600'}`} title="Vista a Griglia"><LayoutGrid size={18}/></button>
                        <button onClick={() => setViewMode('list')} className={`p-1.5 rounded-md transition-all ${viewMode === 'list' ? 'bg-white shadow-sm text-blue-600' : 'text-slate-400 hover:text-slate-600'}`} title="Vista a Lista"><List size={18}/></button>
                    </div>
                    <div className="relative w-full md:w-64"><Search className="absolute left-3 top-1/2 transform -translate-y-1/2 text-slate-400" size={18} /><input type="text" placeholder="Cerca link o etichetta..." value={searchTerm} onChange={e => setSearchTerm(e.target.value)} className="w-full pl-10 pr-4 py-2.5 bg-white border border-slate-200 shadow-sm rounded-xl focus:ring-2 focus:ring-[#9a0002] outline-none transition" /></div>
                    <button onClick={handleCreateNew} className="bg-[#9a0002] text-white px-4 py-2.5 rounded-xl font-bold shadow-md hover:bg-[#7a0001] flex items-center gap-2 transition whitespace-nowrap"><Plus size={18}/> Nuovo Link</button>
                </div>
            </div>

            {filteredLinks.length === 0 ? (
                <div className="bg-white p-12 rounded-xl shadow-sm border border-dashed border-slate-300 text-center text-slate-500"><p className="text-lg font-medium">Nessun link salvato. Aggiungi il primo!</p></div>
            ) : (
                <div className="pb-10 space-y-8 overflow-y-auto custom-scrollbar pr-2">
                    {groupedLinks.map(group => (
                        <div key={group.name} className="animate-in fade-in duration-300 bg-white p-5 rounded-2xl border border-slate-200 shadow-sm">
                            <div className="flex items-center gap-3 mb-5 border-b border-slate-100 pb-3">
                                <div className={`p-2 rounded-lg border ${group.color}`}>{group.icon}</div>
                                <h3 className="text-lg font-extrabold text-slate-800 tracking-tight">{group.name}</h3>
                                <span className="bg-slate-100 border border-slate-200 text-slate-500 text-xs font-bold px-2.5 py-0.5 rounded-md shadow-sm">{group.links.length}</span>
                            </div>
                            
                            {viewMode === 'card' ? (
                                <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                                    {group.links.map(link => {
                                        const theme = LINK_THEMES.find(t => t.id === (link.theme || 'slate')) || LINK_THEMES[0];
                                        return (
                                        <div key={link.id} className={`${theme.bg} rounded-xl p-4 border-2 ${theme.border} flex flex-col relative group/card transition-all shadow-sm hover:shadow-md`}>
                                            <div className="absolute top-2 right-2 flex gap-1 opacity-0 group-hover/card:opacity-100 transition-opacity">
                                                <button onClick={() => { 
                                                    setEditingLink({ ...link, theme: link.theme || 'slate' }); 
                                                    setTagInput(''); setTagColor(tagColors[0].class);
                                                    setShowModal(true); 
                                                }} className="p-1.5 bg-white border border-slate-200 hover:bg-slate-100 text-slate-600 rounded-md transition shadow-sm" title="Modifica"><Edit size={14}/></button>
                                                <button onClick={() => handleDelete(link.id, link.title)} className="p-1.5 bg-white border border-slate-200 hover:bg-red-50 text-red-600 rounded-md transition shadow-sm" title="Elimina"><Trash2 size={14}/></button>
                                            </div>
                                            <div className="flex items-start gap-3 mb-2 pr-12">
                                                <div className={`p-2 rounded-lg ${group.color} mt-0.5 flex-shrink-0 shadow-sm border bg-white`}><ExternalLink size={16}/></div>
                                                <div><h3 className={`font-bold ${theme.textTitle} text-[14px] leading-tight line-clamp-2`} title={link.title}>{link.title}</h3></div>
                                            </div>
                                            
                                            {((link.tags && link.tags.length > 0) || link.customDate) && (
                                                <div className="flex flex-wrap gap-1.5 mb-2 pl-[44px] items-center">
                                                    {link.customDate && (
                                                        <span className={`text-[9px] font-bold px-1.5 py-0.5 rounded border uppercase tracking-wider flex items-center gap-1 bg-white shadow-sm border-slate-200 ${theme.textDesc}`} title="Data di riferimento / Scadenza">
                                                            <Calendar size={10}/> {link.customDate.split('-').reverse().join('/')}
                                                        </span>
                                                    )}
                                                    {(link.tags && link.tags.length > 0) && link.tags.map((t, i) => (
                                                        <span key={i} className={`text-[9px] font-bold px-1.5 py-0.5 rounded border uppercase tracking-wider ${t.colorClass}`}>{t.text}</span>
                                                    ))}
                                                </div>
                                            )}

                                            <p className={`text-[11px] ${theme.textDesc} line-clamp-2 mb-4 flex-1 pl-[44px] ${((link.tags && link.tags.length > 0) || link.customDate) ? 'mt-0' : ''}`}>{link.description || 'Nessuna descrizione inserita.'}</p>
                                            <button onClick={() => window.open(link.url.startsWith('http') ? link.url : `https://${link.url}`, '_blank')} className={`w-full py-2 bg-white ${group.btnClass || 'text-slate-700 hover:bg-slate-50'} font-bold text-xs border border-slate-200 rounded-lg flex justify-center items-center gap-1.5 transition-colors shadow-sm`}>Apri Link</button>
                                        </div>
                                    )})}
                                </div>
                            ) : (
                                <div className="flex flex-col space-y-2">
                                    {group.links.map(link => {
                                        const theme = LINK_THEMES.find(t => t.id === (link.theme || 'slate')) || LINK_THEMES[0];
                                        return (
                                        <div key={link.id} className={`${theme.bg} rounded-xl p-3 border-2 ${theme.border} flex flex-col md:flex-row md:items-center justify-between group/row transition-all shadow-sm hover:shadow-md gap-4`}>
                                            <div className="flex items-center gap-3 flex-1 min-w-0">
                                                <div className={`p-2 rounded-lg ${group.color} flex-shrink-0 shadow-sm border bg-white`}><ExternalLink size={16}/></div>
                                                <div className="flex-1 min-w-0">
                                                    <div className="flex items-center gap-2">
                                                        <h3 className={`font-bold ${theme.textTitle} text-[14px] leading-tight truncate`} title={link.title}>{link.title}</h3>
                                                        {((link.tags && link.tags.length > 0) || link.customDate) && (
                                                            <div className="hidden md:flex flex-wrap gap-1 items-center">
                                                                {link.customDate && (
                                                                    <span className={`text-[9px] font-bold px-1.5 py-0.5 rounded border uppercase tracking-wider flex items-center gap-1 bg-white shadow-sm border-slate-200 ${theme.textDesc}`} title="Data di riferimento / Scadenza">
                                                                        <Calendar size={10}/> {link.customDate.split('-').reverse().join('/')}
                                                                    </span>
                                                                )}
                                                                {(link.tags && link.tags.length > 0) && link.tags.map((t, i) => (
                                                                    <span key={i} className={`text-[9px] font-bold px-1.5 py-0.5 rounded border uppercase tracking-wider ${t.colorClass}`}>{t.text}</span>
                                                                ))}
                                                            </div>
                                                        )}
                                                    </div>
                                                    <p className={`text-[11px] ${theme.textDesc} truncate`} title={link.description}>{link.description || 'Nessuna descrizione inserita.'}</p>
                                                    
                                                    {(link.tags && link.tags.length > 0) && (
                                                        <div className="flex md:hidden flex-wrap gap-1 mt-1.5">
                                                            {link.tags.map((t, i) => (
                                                                <span key={i} className={`text-[9px] font-bold px-1.5 py-0.5 rounded border uppercase tracking-wider ${t.colorClass}`}>{t.text}</span>
                                                            ))}
                                                        </div>
                                                    )}
                                                </div>
                                            </div>
                                            <div className="flex items-center gap-2 flex-shrink-0">
                                                <div className="flex gap-1 opacity-0 md:group-hover/row:opacity-100 transition-opacity mr-2">
                                                    <button onClick={() => { 
                                                        setEditingLink({ ...link, theme: link.theme || 'slate' }); 
                                                        setTagInput(''); setTagColor(tagColors[0].class);
                                                        setShowModal(true); 
                                                    }} className="p-1.5 bg-white border border-slate-200 hover:bg-slate-100 text-slate-600 rounded-md transition shadow-sm" title="Modifica"><Edit size={14}/></button>
                                                    <button onClick={() => handleDelete(link.id, link.title)} className="p-1.5 bg-white border border-slate-200 hover:bg-red-50 text-red-600 rounded-md transition shadow-sm" title="Elimina"><Trash2 size={14}/></button>
                                                </div>
                                                <button onClick={() => window.open(link.url.startsWith('http') ? link.url : `https://${link.url}`, '_blank')} className={`px-4 py-2 bg-white ${group.btnClass || 'text-slate-700 hover:bg-slate-50'} font-bold text-xs border border-slate-200 rounded-lg flex justify-center items-center gap-1.5 transition-colors shadow-sm whitespace-nowrap`}>Apri Link</button>
                                            </div>
                                        </div>
                                    )})}
                                </div>
                            )}
                        </div>
                    ))}
                </div>
            )}

            {showModal && editingLink && (
                <div className="fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4 backdrop-blur-sm">
                    <div className="bg-white rounded-2xl w-full max-w-lg shadow-2xl overflow-hidden animate-in zoom-in-95 duration-200 flex flex-col max-h-[90vh]">
                        <div className="bg-[#1e293b] p-4 flex justify-between items-center text-white flex-shrink-0">
                            <h3 className="font-bold text-lg flex items-center gap-2"><Link size={18}/> {editingLink.id ? 'Modifica Link' : 'Nuovo Link'}</h3>
                            <button onClick={() => { setShowModal(false); setEditingLink(null); }} className="hover:bg-white/20 p-1.5 rounded-lg transition"><X size={20}/></button>
                        </div>
                        
                        <div className="p-6 space-y-4 overflow-y-auto custom-scrollbar">
                            <div><label className="block text-xs font-bold text-slate-500 mb-1.5 uppercase">Nome Piattaforma / Tool</label><input type="text" placeholder="Es. Portale GSE" value={editingLink.title || ''} onChange={e => setEditingLink({...editingLink, title: e.target.value})} className="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg font-bold text-slate-800 focus:ring-2 focus:ring-[#9a0002] outline-none" /></div>
                            <div><label className="block text-xs font-bold text-slate-500 mb-1.5 uppercase">URL (Link)</label><input type="text" placeholder="https://..." value={editingLink.url || ''} onChange={e => setEditingLink({...editingLink, url: e.target.value})} className="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-blue-600 focus:ring-2 focus:ring-[#9a0002] outline-none" /></div>
                            <div className="grid grid-cols-2 gap-4">
                                <div><label className="block text-xs font-bold text-slate-500 mb-1.5 uppercase">Categoria</label><select value={editingLink.category || 'Altro'} onChange={e => setEditingLink({...editingLink, category: e.target.value})} className="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-slate-700 focus:ring-2 focus:ring-[#9a0002] outline-none">{categories.map(c => <option key={c.name} value={c.name}>{c.name}</option>)}</select></div>
                                <div><label className="block text-xs font-bold text-slate-500 mb-1.5 uppercase">Scadenza / Data Rif.</label><input type="date" value={editingLink.customDate || ''} onChange={e => setEditingLink({...editingLink, customDate: e.target.value})} className="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-slate-700 focus:ring-2 focus:ring-[#9a0002] outline-none" /></div>
                            </div>
                            
                            <div className="bg-slate-50 p-4 rounded-xl border border-slate-200">
                                <label className="block text-xs font-bold text-slate-700 mb-3 uppercase flex items-center gap-1.5"><LayoutGrid size={14} className="text-[#9a0002]"/> Sfondo Card (Visibilità)</label>
                                <div className="flex flex-wrap gap-3">
                                    {LINK_THEMES.map(t => (
                                        <button 
                                            key={t.id} 
                                            type="button"
                                            onClick={() => setEditingLink({...editingLink, theme: t.id})}
                                            title={t.label}
                                            className={`w-8 h-8 rounded-full border border-slate-300 shadow-sm transition-all duration-200 ${editingLink.theme === t.id ? 'ring-2 ring-offset-2 ring-slate-800 scale-110' : 'hover:scale-110'} ${t.pickerBg}`}
                                        />
                                    ))}
                                </div>
                            </div>

                            <div className="bg-slate-50 p-4 rounded-xl border border-slate-200">
                                <label className="block text-xs font-bold text-slate-700 mb-2 uppercase flex items-center gap-1.5"><Tag size={14} className="text-[#9a0002]"/> Etichette Personalizzate</label>
                                <div className="flex gap-2 mb-3">
                                    <input type="text" placeholder="Es. Fotovoltaico, Urgente..." value={tagInput} onChange={e => setTagInput(e.target.value)} onKeyPress={e => e.key === 'Enter' && handleAddTag(e)} className="flex-1 px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-[#9a0002] outline-none" />
                                    <button onClick={handleAddTag} type="button" className="bg-white border border-slate-300 hover:bg-slate-100 text-slate-700 px-3 py-2 rounded-lg font-bold text-sm transition shadow-sm">Aggiungi</button>
                                </div>
                                <div className="flex gap-3 mb-3">
                                    {tagColors.map(tc => (
                                        <button 
                                            key={tc.id} 
                                            type="button" 
                                            onClick={() => setTagColor(tc.class)} 
                                            className={`w-6 h-6 rounded-full border border-slate-300 shadow-sm transition-all ${tagColor === tc.class ? 'ring-2 ring-offset-2 ring-slate-800 scale-110' : 'hover:scale-110'} ${tc.pickerBg}`} 
                                            title="Scegli Colore" 
                                        />
                                    ))}
                                </div>
                                {(editingLink.tags && editingLink.tags.length > 0) && (
                                    <div className="flex flex-wrap gap-1.5 pt-3 border-t border-slate-200">
                                        {editingLink.tags.map((t, i) => (
                                            <span key={i} className={`text-[10px] font-bold px-2 py-1 rounded-md border flex items-center gap-1 uppercase tracking-wider shadow-sm ${t.colorClass}`}>
                                                {t.text}
                                                <button onClick={() => handleRemoveTag(i)} type="button" className="hover:bg-black/10 rounded-full p-0.5 transition ml-1"><X size={12}/></button>
                                            </span>
                                        ))}
                                    </div>
                                )}
                            </div>

                            <div><label className="block text-xs font-bold text-slate-500 mb-1.5 uppercase">Descrizione / Note</label><textarea placeholder="Es. Accesso per pratiche di connessione..." value={editingLink.description || ''} onChange={e => setEditingLink({...editingLink, description: e.target.value})} className="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg resize-none focus:ring-2 focus:ring-[#9a0002] outline-none text-slate-700 custom-scrollbar" rows="3" /></div>
                        </div>
                        
                        <div className="bg-slate-50 p-4 border-t border-slate-200 flex justify-end gap-3 flex-shrink-0">
                            <button onClick={() => { setShowModal(false); setEditingLink(null); }} className="px-5 py-2.5 text-slate-600 font-medium hover:bg-slate-100 rounded-lg transition border border-transparent hover:border-slate-200">Annulla</button>
                            <button onClick={handleSaveLink} disabled={isSaving} className="bg-[#9a0002] text-white px-6 py-2.5 rounded-lg font-bold hover:bg-[#7a0001] shadow-md flex items-center gap-2 transition disabled:opacity-50">{isSaving ? <Loader2 size={16} className="animate-spin" /> : <Save size={16}/>} Salva Link</button>
                        </div>
                    </div>
                </div>
            )}
        </div>
    );
}
