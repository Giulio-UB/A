import React, { useState, useEffect } from 'react';
import { initializeApp } from 'firebase/app';
import { getAuth, signInAnonymously, onAuthStateChanged, signInWithCustomToken } from 'firebase/auth';
import { getFirestore, collection, addDoc, updateDoc, doc, query, onSnapshot, deleteDoc, setDoc, getDoc } from 'firebase/firestore';
import { 
  Trash2, Edit, Plus, Save, Printer, Share2, Search, FileText, 
  LayoutGrid, Loader2, ExternalLink, Factory, Home, Trophy,
  Menu, X, Users, Bell, TrendingUp, BarChart3, Gauge, MapPin, Sparkles, Flame, UserCircle, Kanban, ArrowRight, ArrowLeft,
  Check, Activity, Target, Phone, Mail, Folder, Globe, UserCheck, ChevronRight, ChevronLeft, Calculator, StickyNote, Pin, Calendar, Link,
  Camera, UploadCloud, Maximize2, Download, List, Tag, PhoneCall, PhoneForwarded
} from 'lucide-react';

// --- CONFIGURAZIONE FIREBASE ---
const firebaseConfig = JSON.parse(typeof __firebase_config !== 'undefined' ? __firebase_config : '{}');
const app = Object.keys(firebaseConfig).length > 0 ? initializeApp(firebaseConfig) : null;
const auth = app ? getAuth(app) : null;
const db = app ? getFirestore(app) : null;
const appId = typeof __app_id !== 'undefined' ? __app_id : 'default-app-id';

// --- GEMINI API SETUP ---
const apiKey = ""; 

// --- UTILITY COLOR CODING APPUNTI RAPIDI ---
const getNoteCategoryStyle = (category) => {
    switch(category) {
        case 'Normativa': return { badge: 'bg-rose-100 text-rose-700 border-rose-200', border: 'bg-rose-500' };
        case 'Commerciale': return { badge: 'bg-orange-100 text-orange-700 border-orange-200', border: 'bg-orange-500' };
        case 'Tecnico': return { badge: 'bg-blue-100 text-blue-700 border-blue-200', border: 'bg-blue-500' };
        case 'Clienti': return { badge: 'bg-emerald-100 text-emerald-700 border-emerald-200', border: 'bg-emerald-500' };
        case 'Incentivi': return { badge: 'bg-purple-100 text-purple-700 border-purple-200', border: 'bg-purple-500' };
        case 'Task': return { badge: 'bg-cyan-100 text-cyan-700 border-cyan-200', border: 'bg-cyan-500' };
        default: return { badge: 'bg-slate-100 text-slate-700 border-slate-200', border: 'bg-slate-400' };
    }
};

// --- COMPONENTI UI CONDIVISI ---
const MenuItem = ({ icon, label, active, onClick, badge, collapsed }) => (
    <button onClick={onClick} className={`w-full flex items-center ${collapsed ? 'justify-center px-2' : 'justify-between px-4'} py-2.5 rounded-xl transition-all duration-200 group ${active ? 'bg-[#7a0001] text-white shadow-inner' : 'text-slate-200 hover:bg-[#7a0001]/50 hover:text-white'}`} title={collapsed ? label : undefined}>
        <div className="flex items-center gap-3">
            {React.cloneElement(icon, { className: active ? 'text-white' : 'text-slate-400 group-hover:text-white transition-colors' })}
            {!collapsed && <span className="font-medium text-sm truncate">{label}</span>}
        </div>
        {!collapsed && badge && <span className="bg-[#5c0001] text-white text-[9px] font-bold px-2 py-0.5 rounded-md border border-[#7a0001]">{badge}</span>}
    </button>
);

const Input = ({ label, type = 'text', value, onChange, placeholder, isLink }) => (
    <div>
        <label className="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wide flex items-center gap-1">
            {isLink && <Link size={12}/>} {label}
        </label>
        <input type={type} value={value} onChange={e => onChange(e.target.value)} placeholder={placeholder} className={`w-full p-2.5 bg-white border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#9a0002] outline-none transition ${isLink ? 'text-blue-600 font-medium' : 'text-slate-800'}`} />
    </div>
);

const Textarea = ({ label, value, onChange, placeholder }) => (
    <div>
        <label className="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wide">{label}</label>
        <textarea rows={2} value={value} onChange={e => onChange(e.target.value)} placeholder={placeholder} className="w-full p-2.5 bg-white border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#9a0002] outline-none transition text-slate-700 custom-scrollbar" />
    </div>
);

const Select = ({ label, value, onChange, options }) => (
    <div>
        <label className="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wide">{label}</label>
        <select value={value} onChange={e => onChange(e.target.value)} className="w-full p-2.5 bg-white border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#9a0002] outline-none transition text-slate-700">
            <option value="">-- Seleziona --</option>
            {options.map(o => <option key={o} value={o}>{o}</option>)}
        </select>
    </div>
);

const Checkbox = ({ label, checked, onChange }) => (
    <label className="flex items-center cursor-pointer select-none group">
        <div className={`w-5 h-5 rounded border flex items-center justify-center mr-3 transition ${checked ? 'bg-[#9a0002] border-[#9a0002] text-white' : 'bg-white border-slate-300 text-transparent group-hover:border-[#9a0002]/50'}`}>
            <Check size={14} strokeWidth={3} />
        </div>
        <input type="checkbox" checked={checked} onChange={e => onChange(e.target.checked)} className="hidden" />
        <span className={`text-sm font-medium transition ${checked ? 'text-slate-800' : 'text-slate-600'}`}>{label}</span>
    </label>
);

// --- COMPONENTE PRINCIPALE (LAYOUT ROOT) ---
export default function App() {
  const [user, setUser] = useState(null);
  const [loading, setLoading] = useState(true);
  const [activeModule, setActiveModule] = useState('dashboard'); 
  const [isSidebarOpen, setIsSidebarOpen] = useState(false);
  const [isSidebarCollapsed, setIsSidebarCollapsed] = useState(false);
  
  useEffect(() => {
    if (!auth) {
        setLoading(false);
        return;
    }
    const initAuth = async () => {
      try {
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
          await signInWithCustomToken(auth, __initial_auth_token);
        } else {
          await signInAnonymously(auth);
        }
      } catch (err) { console.error("Auth Error", err); }
    };
    initAuth();
    const unsubscribe = onAuthStateChanged(auth, (u) => { setUser(u); if(!u) setLoading(false); });
    return () => unsubscribe();
  }, []);

  const toggleSidebar = () => setIsSidebarOpen(!isSidebarOpen);

  const navigateToModule = (moduleName) => {
      setActiveModule(moduleName);
      setIsSidebarOpen(false);
  };

  const getModuleTitle = () => {
      switch(activeModule) {
          case 'dashboard': return 'Pannello di Controllo';
          case 'pipeline': return 'Pipeline Lead';
          case 'calls': return 'Cronologia Contatti';
          case 'audits': return 'Audit Manager';
          case 'audits-new': return 'Nuovo Audit';
          case 'clients': return 'Gestione Clienti';
          case 'notes': return 'Appunti Rapidi';
          case 'links': return 'Gestione Link';
          case 'gallery': return 'Archivio Foto';
          default: return 'Gestionale';
      }
  };

  const getModuleIcon = () => {
      switch(activeModule) {
          case 'dashboard': return <LayoutGrid size={24} className="text-[#9a0002]" />;
          case 'pipeline': return <Kanban size={24} className="text-[#9a0002]" />;
          case 'calls': return <PhoneCall size={24} className="text-[#9a0002]" />;
          case 'audits': 
          case 'audits-new': return <LayoutGrid size={24} className="text-orange-600" />;
          case 'clients': return <Users size={24} className="text-[#059669]" />;
          case 'notes': return <StickyNote size={24} className="text-yellow-600" />;
          case 'links': return <Link size={24} className="text-blue-600" />;
          case 'gallery': return <Camera size={24} className="text-teal-600" />;
          default: return <LayoutGrid size={24} className="text-[#9a0002]" />;
      }
  };

  if (loading) return <div className="flex h-screen items-center justify-center bg-slate-50 text-[#9a0002] gap-2"><Loader2 className="animate-spin" /> Inizializzazione Ambiente...</div>;

  return (
    <div className="flex h-screen bg-slate-100 font-sans text-slate-800 overflow-hidden">
      
      {/* SIDEBAR ESSENZIALE (COLLAPSE) */}
      <aside className={`
        fixed inset-y-0 left-0 z-50 bg-[#9a0002] text-white transform transition-all duration-300 ease-in-out shadow-2xl flex flex-col
        ${isSidebarOpen ? 'translate-x-0' : '-translate-x-full'} 
        md:translate-x-0 md:static md:flex-shrink-0
        ${isSidebarCollapsed ? 'w-20' : 'w-64'}
      `}>
        <div className="h-16 flex items-center justify-center px-4 border-b border-[#7a0001] bg-[#8a0002] flex-shrink-0 transition-all">
          <div className="flex items-center gap-3 font-bold text-lg tracking-tight w-full" style={{ justifyContent: isSidebarCollapsed ? 'center' : 'flex-start' }}>
            <div className="w-8 h-8 bg-white rounded-full flex items-center justify-center text-[#9a0002] shadow-sm font-black flex-shrink-0">G</div>
            {!isSidebarCollapsed && <span className="text-white truncate">Giulio Consulente</span>}
          </div>
          {!isSidebarCollapsed && <button onClick={toggleSidebar} className="md:hidden ml-auto text-slate-100 hover:text-white"><X size={24} /></button>}
        </div>

        <nav className="p-3 space-y-1.5 flex-1 overflow-y-auto custom-scrollbar overflow-x-hidden">
          {!isSidebarCollapsed && <div className="text-[10px] font-bold text-white/60 uppercase tracking-widest mb-2 px-2 mt-2">Core Business</div>}
          <MenuItem icon={<Gauge size={20} />} label="Pannello di Controllo" active={activeModule === 'dashboard'} onClick={() => navigateToModule('dashboard')} collapsed={isSidebarCollapsed} />
          <MenuItem icon={<Kanban size={20} />} label="Pipeline Lead" active={activeModule === 'pipeline'} onClick={() => navigateToModule('pipeline')} badge="Vendite" collapsed={isSidebarCollapsed} />
          <MenuItem icon={<LayoutGrid size={20} />} label="Audit Manager" active={activeModule === 'audits' || activeModule === 'audits-new'} onClick={() => navigateToModule('audits')} collapsed={isSidebarCollapsed} />
          <MenuItem icon={<Users size={20} />} label="Gestione Clienti" active={activeModule === 'clients'} onClick={() => navigateToModule('clients')} collapsed={isSidebarCollapsed} />
          
          {!isSidebarCollapsed && <div className="text-[10px] font-bold text-white/60 uppercase tracking-widest mb-2 px-2 mt-4 border-t border-[#7a0001] pt-4">Utility & Risorse</div>}
          {isSidebarCollapsed && <div className="border-t border-[#7a0001] my-3 mx-2"></div>}
          
          <MenuItem icon={<Camera size={20} />} label="Archivio Foto" active={activeModule === 'gallery'} onClick={() => navigateToModule('gallery')} collapsed={isSidebarCollapsed} />
          <MenuItem icon={<StickyNote size={20} />} label="Appunti Rapidi" active={activeModule === 'notes'} onClick={() => navigateToModule('notes')} collapsed={isSidebarCollapsed} />
          <MenuItem icon={<PhoneCall size={20} />} label="Cronologia Contatti" active={activeModule === 'calls'} onClick={() => navigateToModule('calls')} collapsed={isSidebarCollapsed} />
          <MenuItem icon={<Link size={20} />} label="Gestione Link" active={activeModule === 'links'} onClick={() => navigateToModule('links')} collapsed={isSidebarCollapsed} />
        </nav>

        <div className="p-4 border-t border-[#7a0001] bg-[#8a0002] flex-shrink-0 transition-all">
          <div className={`flex items-center ${isSidebarCollapsed ? 'justify-center' : 'gap-3'}`}>
            <div className="w-9 h-9 rounded-full bg-white flex items-center justify-center text-[#9a0002] shadow-sm flex-shrink-0"><span className="font-bold text-xs">GC</span></div>
            {!isSidebarCollapsed && (
              <div className="flex-1 min-w-0">
                <p className="text-sm font-bold text-white truncate">Giulio C.</p>
                <p className="text-[10px] text-red-200 uppercase tracking-wider truncate">Pro Account</p>
              </div>
            )}
          </div>
        </div>
      </aside>

      {isSidebarOpen && <div className="fixed inset-0 bg-black/50 z-40 md:hidden" onClick={toggleSidebar}></div>}

      <main className="flex-1 flex flex-col min-w-0 overflow-hidden bg-slate-50">
        
        {/* HEADER GLOBALE */}
        <header className="bg-white h-16 flex items-center justify-between px-4 md:px-6 sticky top-0 z-30 border-b border-slate-200 shadow-sm">
          <div className="flex items-center gap-3 md:gap-4">
            <button onClick={toggleSidebar} className="md:hidden text-slate-500 hover:bg-slate-100 hover:text-slate-800 p-2 rounded-lg transition"><Menu size={24} /></button>
            
            <button onClick={() => setIsSidebarCollapsed(!isSidebarCollapsed)} className="hidden md:flex items-center justify-center w-8 h-8 bg-[#059669] text-white rounded-full hover:bg-[#047857] transition-colors shadow-md z-40">
                {isSidebarCollapsed ? <ChevronRight size={18} strokeWidth={3} /> : <ChevronLeft size={18} strokeWidth={3} />}
            </button>
            
            <h1 className="font-black text-slate-800 text-xl tracking-tight hidden md:flex items-center gap-2.5">
                {getModuleIcon()} {getModuleTitle()}
            </h1>
            <h1 className="font-extrabold text-slate-800 text-lg tracking-tight md:hidden">{getModuleTitle()}</h1>
          </div>
          <div className="flex items-center gap-4">
             <button className="text-slate-400 hover:text-slate-600 transition"><Bell size={20}/></button>
          </div>
        </header>

        {/* RENDER MODULI */}
        <div className="flex-1 overflow-y-auto p-4 md:p-8 custom-scrollbar relative">
          {activeModule === 'dashboard' && <DashboardOverview user={user} appId={appId} navigateToModule={navigateToModule} />}
          {activeModule === 'pipeline' && <PipelineModule user={user} appId={appId} />}
          {activeModule === 'calls' && <CallsModule user={user} appId={appId} navigateToModule={navigateToModule} />}
          {(activeModule === 'audits' || activeModule === 'audits-new') && <AuditManager key={activeModule} user={user} appId={appId} initialMode={activeModule === 'audits-new' ? 'new' : 'list'} setActiveModule={setActiveModule} />}
          {activeModule === 'clients' && <ClientsModule user={user} appId={appId} navigateToModule={navigateToModule} />}
          {activeModule === 'gallery' && <GalleryModule user={user} appId={appId} />}
          {activeModule === 'notes' && <NotesModule user={user} appId={appId} />}
          {activeModule === 'links' && <LinksModule user={user} appId={appId} />}
        </div>
      </main>
    </div>
  );
}

// --- 1. MODULO DASHBOARD OVERVIEW ---
function DashboardOverview({ user, appId, navigateToModule }) {
    const [stats, setStats] = useState({ audits: 0, pipeline: 0, clients: 0, recentAudits: [] });
    const [loading, setLoading] = useState(true);

    const [pipelineVal, setPipelineVal] = useState(0);
    const [activeLeadsCount, setActiveLeadsCount] = useState(0);

    const [recentNotes, setRecentNotes] = useState([]);
    
    // Links and Tools Setup
    const [driveLink, setDriveLink] = useState('');
    const [sheetsLink, setSheetsLink] = useState('');
    const [editingLinkType, setEditingLinkType] = useState(null); 
    const [tempUrl, setTempUrl] = useState('');
    
    const [isEditingTools, setIsEditingTools] = useState(false);
    const [isSavingTools, setIsSavingTools] = useState(false);
    const [toolLinks, setToolLinks] = useState([
        { title: 'Gestione Contabilità', url: '' },
        { title: 'Simulatore Autoconsumo GSE', url: 'https://www.autoconsumo.gse.it/' },
        { title: 'Dimensionatore PDC Pro', url: '' },
        { title: 'Gestione Contatti Pro', url: '' },
        { title: 'Dimensionatore Clima Pro', url: '' }
    ]);

    useEffect(() => {
        if (!user || !db) return;

        const unsubAudits = onSnapshot(collection(db, 'artifacts', appId, 'users', user.uid, 'audits'), (snap) => {
            const auditData = snap.docs.map(d => ({...d.data(), id: d.id}));
            auditData.sort((a, b) => new Date(b.dataRilievo || '1970-01-01') - new Date(a.dataRilievo || '1970-01-01'));
            setStats(prev => ({ ...prev, audits: snap.size, recentAudits: auditData.slice(0, 5) }));
            setLoading(false);
        });

        const unsubOpps = onSnapshot(collection(db, 'artifacts', appId, 'users', user.uid, 'leads'), (snap) => {
            let val = 0;
            let count = 0;
            snap.docs.forEach(d => {
                const data = d.data();
                if (['Da Contattare', 'In Contatto', 'Sopralluogo Fissato', 'Preventivo Inviato', 'In Negoziazione'].includes(data.stage)) {
                    val += Number(data.expectedValue) || 0;
                    count++;
                }
            });
            setPipelineVal(val);
            setActiveLeadsCount(count);
            setStats(prev => ({ ...prev, pipeline: snap.size }));
        });

        const unsubClients = onSnapshot(collection(db, 'artifacts', appId, 'users', user.uid, 'clients'), (snap) => {
            setStats(prev => ({ ...prev, clients: snap.size }));
        });
        
        const unsubSettings = onSnapshot(doc(db, 'artifacts', appId, 'users', user.uid, 'settings', 'dashboard'), (snap) => {
            if (snap.exists()) {
                const data = snap.data();
                if (data.driveLink !== undefined) setDriveLink(data.driveLink);
                if (data.sheetsLink !== undefined) setSheetsLink(data.sheetsLink);
                if (data.toolLinks !== undefined) setToolLinks(data.toolLinks);
            }
        });

        const unsubNotes = onSnapshot(collection(db, 'artifacts', appId, 'users', user.uid, 'notes'), (snap) => {
            const notesData = snap.docs.map(d => ({id: d.id, ...d.data()}));
            notesData.sort((a, b) => new Date(b.createdAt || 0) - new Date(a.createdAt || 0));
            setRecentNotes(notesData.slice(0, 3));
        });

        return () => { unsubAudits(); unsubOpps(); unsubClients(); unsubSettings(); unsubNotes(); };
    }, [user, appId]);

    const handleSaveMainLink = async () => {
        if (editingLinkType === 'drive') {
            await setDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'settings', 'dashboard'), { driveLink: tempUrl }, { merge: true });
        } else if (editingLinkType === 'sheets') {
            await setDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'settings', 'dashboard'), { sheetsLink: tempUrl }, { merge: true });
        }
        setEditingLinkType(null);
    };

    const handleSaveTools = async () => {
        setIsSavingTools(true);
        try {
            await setDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'settings', 'dashboard'), { toolLinks }, { merge: true });
            setIsEditingTools(false);
        } catch (error) { console.error(error); } finally { setIsSavingTools(false); }
    };

    if (loading) return <div className="p-10 text-center text-slate-500"><Loader2 className="animate-spin mx-auto text-[#9a0002] mb-3" />Caricamento Pannello di Controllo...</div>;

    return (
        <div className="space-y-6 animate-in fade-in duration-300 max-w-[1600px] mx-auto">
            
            {/* STRISCIA ROSSA BENTORNATO */}
            <div className="bg-[#9a0002] rounded-2xl p-6 md:p-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 relative overflow-hidden shadow-lg border border-[#7a0001]">
                <div className="absolute right-0 top-0 bottom-0 w-full md:w-1/2 overflow-hidden pointer-events-none opacity-10">
                    <div className="absolute -right-20 -top-40 w-96 h-96 border-[40px] border-white rounded-full"></div>
                    <div className="absolute -right-10 -top-20 w-72 h-72 border-[20px] border-white rounded-full"></div>
                    <div className="absolute right-10 top-0 w-40 h-40 border-[10px] border-white rounded-full"></div>
                </div>

                <div className="relative z-10">
                    <h1 className="text-3xl md:text-4xl font-extrabold text-white tracking-tight mb-2">Bentornato, Giulio! 👋</h1>
                    <p className="text-red-100 font-medium text-sm md:text-base tracking-wide">Ecco il riepilogo delle tue attività e performance di oggi.</p>
                </div>
                
                <button onClick={() => navigateToModule('pipeline')} className="relative z-10 bg-white text-[#9a0002] px-6 py-3.5 rounded-xl font-extrabold shadow-md hover:bg-slate-100 transition-all hover:scale-105 flex items-center gap-2 whitespace-nowrap">
                    <Plus size={18} strokeWidth={3} /> Nuova Trattativa
                </button>
            </div>

            {/* AZIONI RAPIDE */}
            <div>
                <div className="flex justify-between items-center mb-3">
                    <h3 className="font-bold text-yellow-600 text-[11px] uppercase tracking-wider flex items-center gap-1.5"><Flame size={14}/> Azioni Rapide</h3>
                </div>
                
                <div className="grid grid-cols-1 md:grid-cols-3 xl:grid-cols-5 gap-4">
                    <div className="bg-white p-4 rounded-xl shadow-sm border border-slate-200 flex items-center justify-between gap-4 hover:border-purple-300 hover:shadow-md transition cursor-pointer group" onClick={() => navigateToModule('pipeline')}>
                        <div className="flex items-center gap-3 w-full">
                            <div className="p-3 bg-purple-50 text-purple-600 rounded-full group-hover:bg-purple-100 transition-colors"><Target size={22}/></div>
                            <div className="flex-1 min-w-0">
                                <p className="font-black text-slate-800 text-[16px] leading-tight truncate">€ {pipelineVal.toLocaleString('it-IT')}</p>
                                <p className="text-[10px] font-bold text-slate-500 uppercase tracking-wide truncate mt-0.5">Pipeline ({activeLeadsCount} attivi)</p>
                            </div>
                        </div>
                    </div>

                    <div className="bg-white p-4 rounded-xl shadow-sm border border-slate-200 flex items-center justify-between gap-4 hover:border-red-300 hover:shadow-md transition cursor-pointer group" onClick={() => navigateToModule('audits-new')}>
                        <div className="flex items-center gap-3 w-full">
                            <div className="p-3 bg-red-50 text-red-500 rounded-full group-hover:bg-red-100 transition-colors"><FileText size={22}/></div>
                            <div className="flex-1 min-w-0">
                                <p className="font-bold text-slate-800 text-[14px] leading-tight truncate">Nuovo Rilievo</p>
                                <p className="text-[10px] text-slate-500 uppercase tracking-wide truncate mt-0.5">Compila Audit</p>
                            </div>
                        </div>
                    </div>

                    <div className="bg-white p-4 rounded-xl shadow-sm border border-slate-200 flex items-center justify-between gap-4 hover:border-blue-300 hover:shadow-md transition group relative">
                        {editingLinkType === 'drive' ? (
                            <div className="flex w-full items-center gap-2">
                                <input type="text" value={tempUrl} onChange={e => setTempUrl(e.target.value)} placeholder="Incolla link..." className="w-full text-xs p-2 bg-slate-50 border border-slate-300 rounded-lg outline-none focus:ring-1 focus:ring-blue-500" autoFocus />
                                <button onClick={handleSaveMainLink} className="bg-blue-600 text-white p-2 rounded-lg hover:bg-blue-700 shadow-sm"><Check size={14}/></button>
                            </div>
                        ) : (
                            <>
                                <div className="flex items-center gap-3 w-full cursor-pointer" onClick={() => driveLink ? window.open(driveLink.startsWith('http') ? driveLink : `https://${driveLink}`, '_blank') : setEditingLinkType('drive')}>
                                    <div className="p-3 bg-blue-50 text-blue-500 rounded-full group-hover:bg-blue-100 transition-colors"><Folder size={22}/></div>
                                    <div className="flex-1 min-w-0">
                                        <p className="font-bold text-slate-800 text-[14px] leading-tight truncate">Drive Master</p>
                                        <p className="text-[10px] text-slate-500 uppercase tracking-wide truncate mt-0.5">Archivio Commerciale</p>
                                    </div>
                                </div>
                                <button onClick={(e) => { e.stopPropagation(); setEditingLinkType('drive'); setTempUrl(driveLink); }} className="absolute top-2 right-2 p-1.5 opacity-0 group-hover:opacity-100 text-slate-400 hover:text-blue-600 transition bg-white rounded-md shadow-sm border border-slate-100"><Edit size={12}/></button>
                            </>
                        )}
                    </div>

                    <div className="bg-white p-4 rounded-xl shadow-sm border border-slate-200 flex items-center justify-between gap-4 hover:border-green-300 hover:shadow-md transition group relative">
                         {editingLinkType === 'sheets' ? (
                            <div className="flex w-full items-center gap-2">
