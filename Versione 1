                        <input type="text" value={newCall.contactName} onChange={e => setNewCall({...newCall, contactName: e.target.value})} placeholder="Es. Rossi S.r.l." className="w-full p-2.5 bg-white border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#9a0002] outline-none transition text-slate-800 font-bold" />
                    </div>
                    <div className="md:col-span-2">
                        <label className="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wide">Data</label>
                        <input type="date" value={newCall.date} onChange={e => setNewCall({...newCall, date: e.target.value})} className="w-full p-2.5 bg-white border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#9a0002] outline-none transition text-slate-800" />
                    </div>
                    <div className="md:col-span-2">
                        <label className="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wide">Esito</label>
                        <select value={newCall.outcome} onChange={e => setNewCall({...newCall, outcome: e.target.value})} className={`w-full p-2.5 border rounded-lg focus:ring-2 focus:ring-[#9a0002] outline-none transition font-bold ${getOutcomeStyle(newCall.outcome)}`}>
