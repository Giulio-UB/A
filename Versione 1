                    <div className="bg-green-100 p-3 rounded-xl text-green-600"><Target size={24} /></div>
                </div>
                <div className="bg-white p-5 rounded-xl shadow-sm border border-orange-200 flex items-center justify-between relative overflow-hidden">
                    <div className="absolute top-0 left-0 w-1.5 h-full bg-orange-500"></div>
                    <div><p className="text-[11px] font-bold text-orange-700 uppercase tracking-wide">Follow-Up (Da Richiamare)</p><p className="text-2xl font-black text-orange-800 mt-1">{pendingCalls}</p></div>
