// --- 2. MODULO PIPELINE LEAD ---
function PipelineModule({ user, appId }) {
    const [leads, setLeads] = useState([]);
    const [loading, setLoading] = useState(true);
    const [showModal, setShowModal] = useState(false);
    const [currentLead, setCurrentLead] = useState({ company: '', name: '', expectedValue: '', stage: 'Da Contattare', type: 'Azienda', phone: '', email: '', notes: '' });
    
    const stagesConfig = [
        { id: 'Da Contattare', label: 'DA CONTATTARE', headBg: 'bg-slate-100', text: 'text-slate-800', badgeBg: 'bg-slate-800' },
        { id: 'In Contatto', label: 'IN CONTATTO', headBg: 'bg-blue-100', text: 'text-blue-800', badgeBg: 'bg-blue-600' },
        { id: 'Sopralluogo Fissato', label: 'SOPRALLUOGO FISSATO', headBg: 'bg-indigo-100', text: 'text-indigo-800', badgeBg: 'bg-indigo-600' },
        { id: 'Preventivo Inviato', label: 'PREVENTIVO INVIATO', headBg: 'bg-yellow-100', text: 'text-yellow-800', badgeBg: 'bg-yellow-500' },
        { id: 'In Negoziazione', label: 'IN NEGOZIAZIONE', headBg: 'bg-orange-100', text: 'text-orange-800', badgeBg: 'bg-orange-500' },
        { id: 'Chiusa Vinta', label: 'CHIUSA VINTA', headBg: 'bg-emerald-100', text: 'text-emerald-800', badgeBg: 'bg-emerald-600' },
        { id: 'Persa', label: 'PERSA', headBg: 'bg-red-100', text: 'text-red-800', badgeBg: 'bg-red-600' }
    ];

    const stagesOptions = stagesConfig.map(s => s.id);

    useEffect(() => {
        if (!user) return;
        return onSnapshot(collection(db, 'artifacts', appId, 'users', user.uid, 'leads'), (snap) => {
            const data = snap.docs.map(d => {
                let leadData = d.data();
                if (leadData.stage === 'In Trattativa') leadData.stage = 'In Negoziazione';
                if (leadData.stage === 'Vinto') leadData.stage = 'Chiusa Vinta';
                if (leadData.stage === 'Perso') leadData.stage = 'Persa';
                return { id: d.id, ...leadData };
            });
            data.sort((a,b) => new Date(b.createdAt||0).getTime() - new Date(a.createdAt||0).getTime());
            setLeads(data);
            setLoading(false);
        });
    }, [user, appId]);

    const handleSave = async () => {
        if (!currentLead.company) return;
        const payload = { ...currentLead };
        if (currentLead.id) {
            const { id, ...data } = payload;
            await updateDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'leads', id), data);
        } else {
            await addDoc(collection(db, 'artifacts', appId, 'users', user.uid, 'leads'), { ...payload, createdAt: new Date().toISOString() });
        }
        setShowModal(false);
        setCurrentLead({ company: '', name: '', expectedValue: '', stage: 'Da Contattare', type: 'Azienda', phone: '', email: '', notes: '' });
    };

    const updateStage = async (id, stage) => await updateDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'leads', id), { stage });
    const deleteLead = async (id) => await deleteDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'leads', id));

    const handleDragStart = (e, leadId) => e.dataTransfer.setData('leadId', leadId);
    const handleDragOver = (e) => e.preventDefault();
    const handleDrop = async (e, targetStage) => {
        e.preventDefault();
        const leadId = e.dataTransfer.getData('leadId');
        if (leadId) await updateStage(leadId, targetStage);
    };

    const getTypeConfig = (type) => {
        switch(type) {
            case 'Azienda': return { color: 'text-indigo-700', bg: 'bg-indigo-50', border: 'bg-indigo-500', icon: <Factory size={10}/> };
            case 'Residenziale': return { color: 'text-[#9a0002]', bg: 'bg-[#9a0002]/10', border: 'bg-[#9a0002]', icon: <Home size={10}/> };
            case 'ASD': return { color: 'text-yellow-700', bg: 'bg-yellow-100', border: 'bg-yellow-500', icon: <Trophy size={10}/> };
            default: return { color: 'text-slate-600', bg: 'bg-slate-100', border: 'bg-slate-400', icon: <UserCircle size={10}/> };
        }
    };

    if (loading) return <div className="p-10 text-center"><Loader2 className="animate-spin mx-auto text-[#9a0002]"/></div>;

    return (
        <div className="h-full flex flex-col animate-in fade-in duration-300">
            <div className="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
                <div className="flex items-center gap-3">
                    <div className="bg-[#9a0002]/10 text-[#9a0002] p-2.5 rounded-xl border border-[#9a0002]/20"><Kanban size={24}/></div>
                    <div>
                        <h2 className="text-2xl font-extrabold text-slate-800 tracking-tight">Pipeline Lead</h2>
                        <p className="text-xs font-medium text-slate-500 mt-0.5">Trascina le card per aggiornare lo stato (Drag & Drop).</p>
                    </div>
                </div>
                <button onClick={() => { setCurrentLead({ company: '', name: '', expectedValue: '', stage: 'Da Contattare', type: 'Azienda', phone: '', email: '', notes: '' }); setShowModal(true); }} className="bg-[#9a0002] text-white px-5 py-2.5 rounded-xl font-bold shadow-md hover:bg-[#7a0001] flex items-center gap-2 transition whitespace-nowrap">
                    <Plus size={18}/> Nuova Opportunità
                </button>
            </div>
            
            <div className="flex gap-4 overflow-x-auto pb-6 flex-1 custom-scrollbar items-stretch">
                {stagesConfig.map(stage => (
                    <div 
                        key={stage.id} 
                        onDragOver={handleDragOver}
                        onDrop={(e) => handleDrop(e, stage.id)}
                        className="w-[280px] xl:w-[300px] flex-shrink-0 flex flex-col h-full"
                    >
                        <div className={`p-3 font-extrabold text-[11px] uppercase tracking-wider rounded-t-xl border border-b-0 border-slate-200 flex justify-between items-center shadow-sm ${stage.headBg} ${stage.text}`}>
                            {stage.label} 
                            <span className={`px-2 py-0.5 rounded-full text-white text-[10px] shadow-sm flex items-center justify-center min-w-[20px] ${stage.badgeBg}`}>
                                {leads.filter(l => l.stage === stage.id).length}
                            </span>
                        </div>

                        <div className="p-3 flex-1 overflow-y-auto space-y-3 custom-scrollbar bg-slate-50/50 rounded-b-xl border border-slate-200 shadow-inner min-h-[60vh]">
                            <div className="border border-dashed border-slate-300 rounded-lg py-3 flex justify-center items-center text-[10px] font-bold text-slate-400 tracking-widest uppercase bg-white/50 mb-2">
                                Trascina Qui
                            </div>

                            {leads.filter(l => l.stage === stage.id).map(lead => {
                                const tConfig = getTypeConfig(lead.type);
                                return (
                                    <div 
                                        key={lead.id} 
                                        draggable
                                        onDragStart={(e) => handleDragStart(e, lead.id)}
                                        className="bg-white p-3.5 rounded-xl shadow-sm border border-slate-200 hover:shadow-md hover:border-blue-400 transition-all cursor-grab active:cursor-grabbing relative group"
                                    >
                                        <div className={`absolute left-0 top-0 bottom-0 w-1.5 rounded-l-xl ${tConfig.border}`}></div>
                                        
                                        <div className="pl-2">
                                            <div className="flex justify-between items-start mb-2">
                                                <span className={`text-[9px] font-black uppercase tracking-wider px-1.5 py-0.5 rounded flex items-center gap-1 ${tConfig.bg} ${tConfig.color}`}>
                                                    {tConfig.icon} {lead.type || 'Azienda'}
                                                </span>
                                                <span className="text-[12px] font-black text-emerald-600">
                                                    € {lead.expectedValue ? Number(lead.expectedValue).toLocaleString('it-IT') : '0'}
                                                </span>
                                            </div>
                                            
                                            <h4 className="font-extrabold text-slate-800 text-[14px] leading-tight truncate pr-2" title={lead.company}>{lead.company}</h4>
                                            {lead.name && <p className="text-[11px] font-medium text-slate-500 mt-1 truncate">{lead.name}</p>}
                                            
                                            <div className="mt-3 pt-3 border-t border-slate-100 flex justify-between items-center text-[10px] text-slate-400">
                                                <span className="flex items-center gap-1.5 font-bold tracking-wider"><Calendar size={12} className="text-slate-300"/> {lead.createdAt ? new Date(lead.createdAt).toLocaleDateString('it-IT') : '-'}</span>
                                                
                                                <div className="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                                    <button onClick={(e) => { e.stopPropagation(); setCurrentLead(lead); setShowModal(true); }} className="text-blue-600 hover:bg-blue-50 p-1.5 rounded-md transition border border-transparent hover:border-blue-200 shadow-sm" title="Modifica"><Edit size={14}/></button>
                                                    <button onClick={(e) => { e.stopPropagation(); deleteLead(lead.id); }} className="text-red-600 hover:bg-red-50 p-1.5 rounded-md transition border border-transparent hover:border-red-200 shadow-sm" title="Elimina"><Trash2 size={14}/></button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                );
                            })}
                        </div>
                    </div>
                ))}
            </div>

            {showModal && (
                <div className="fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4 backdrop-blur-sm">
                    <div className="bg-white rounded-2xl w-full max-w-2xl shadow-2xl overflow-hidden animate-in fade-in zoom-in duration-200">
                        <div className="bg-[#9a0002] p-5 flex justify-between items-center text-white">
                            <h3 className="font-bold text-lg flex items-center gap-2"><Kanban size={20}/> {currentLead.id ? 'Modifica Opportunità' : 'Nuova Opportunità Lead'}</h3>
                            <button onClick={() => setShowModal(false)} className="hover:bg-white/20 p-1.5 rounded-lg transition"><X size={20}/></button>
                        </div>
                        <div className="p-6 md:p-8 max-h-[75vh] overflow-y-auto custom-scrollbar">
                            <div className="space-y-5">
                                <div className="grid grid-cols-1 md:grid-cols-2 gap-5">
                                    <Input label="Azienda / Cliente *" value={currentLead.company || ''} onChange={v => setCurrentLead({...currentLead, company: v})} placeholder="Es. Rossi S.r.l." />
                                    <Select label="Fase Pipeline" value={currentLead.stage || 'Da Contattare'} onChange={v => setCurrentLead({...currentLead, stage: v})} options={stagesOptions} />
                                </div>
                                <div className="grid grid-cols-1 md:grid-cols-2 gap-5">
                                    <Input label="Referente / Decisore" value={currentLead.name || ''} onChange={v => setCurrentLead({...currentLead, name: v})} placeholder="Nome e Cognome" />
                                    <Input label="Valore Atteso (€)" type="number" value={currentLead.expectedValue || ''} onChange={v => setCurrentLead({...currentLead, expectedValue: v})} placeholder="Es. 15000" />
                                </div>
                                <div className="grid grid-cols-1 md:grid-cols-3 gap-5 bg-slate-50 p-4 rounded-xl border border-slate-200">
                                    <Select label="Tipologia Cliente" value={currentLead.type || 'Azienda'} onChange={v => setCurrentLead({...currentLead, type: v})} options={['Azienda', 'Residenziale', 'ASD']} />
                                    <Input label="Telefono" value={currentLead.phone || ''} onChange={v => setCurrentLead({...currentLead, phone: v})} placeholder="Es. 333..." />
                                    <Input label="Email" value={currentLead.email || ''} onChange={v => setCurrentLead({...currentLead, email: v})} placeholder="Es. info@..." />
                                </div>
                                <Textarea label="Note Trattativa / Esigenze" value={currentLead.notes || ''} onChange={v => setCurrentLead({...currentLead, notes: v})} placeholder="Dettagli dell'offerta, tempistiche decisionali..." />
                            </div>
                        </div>
                        <div className="bg-slate-50 p-5 border-t border-slate-200 flex justify-end gap-3">
                            <button onClick={() => setShowModal(false)} className="px-5 py-2.5 rounded-xl font-medium text-slate-600 hover:bg-slate-200 transition">Annulla</button>
                            <button onClick={handleSave} className="bg-[#9a0002] hover:bg-[#7a0001] text-white px-6 py-2.5 rounded-xl font-bold shadow-md flex items-center gap-2 transition">Salva Lead</button>
                        </div>
                    </div>
                </div>
            )}
        </div>
    );
}

// --- 3. MODULO CRONOLOGIA CONTATTI ---
function CallsModule({ user, appId, navigateToModule }) {
    const [calls, setCalls] = useState([]);
    const [loading, setLoading] = useState(true);
    const [isSaving, setIsSaving] = useState(false);
    const [searchTerm, setSearchTerm] = useState('');
    const [dialog, setDialog] = useState(null);

    const initialCallState = { contactName: '', date: new Date().toISOString().split('T')[0], outcome: 'Da Richiamare', notes: '' };
    const [newCall, setNewCall] = useState(initialCallState);

    useEffect(() => {
        if (!user) return;
        return onSnapshot(collection(db, 'artifacts', appId, 'users', user.uid, 'cronologia_chiamate'), (snap) => {
            const data = snap.docs.map(doc => ({ id: doc.id, ...doc.data() }));
            data.sort((a, b) => new Date(b.date || 0).getTime() - new Date(a.date || 0).getTime());
            setCalls(data); setLoading(false);
        });
    }, [user, appId]);

    const handleSaveCall = async () => {
        if (!newCall.contactName) { setDialog({ title: "Attenzione", message: "Inserisci il nome del contatto.", type: 'alert', onConfirm: () => setDialog(null) }); return; }
        setIsSaving(true);
        try {
            await addDoc(collection(db, 'artifacts', appId, 'users', user.uid, 'cronologia_chiamate'), { ...newCall, createdAt: new Date().toISOString() });
            setNewCall(initialCallState);
        } catch (e) { setDialog({ title: "Errore", message: "Impossibile salvare.", type: 'alert', onConfirm: () => setDialog(null) }); } finally { setIsSaving(false); }
    };

    const handleDeleteCall = async (id, name) => {
        setDialog({ title: "Elimina", message: `Vuoi eliminare lo storico di "${name}"?`, type: 'confirm', onConfirm: async () => { setDialog(null); await deleteDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'cronologia_chiamate', id)); }, onCancel: () => setDialog(null) });
    };

    const getOutcomeStyle = (outcome) => {
        switch(outcome) {
            case 'Positivo': return 'bg-green-50 text-green-700 border-green-200';
            case 'Negativo': return 'bg-red-50 text-red-700 border-red-200';
            case 'Da Richiamare': return 'bg-orange-50 text-orange-700 border-orange-200';
            default: return 'bg-slate-50 text-slate-700 border-slate-200';
        }
    };

    const filteredCalls = calls.filter(c => (c.contactName || '').toLowerCase().includes(searchTerm.toLowerCase()) || (c.notes || '').toLowerCase().includes(searchTerm.toLowerCase()));
    const totalCalls = calls.length;
    const positiveCalls = calls.filter(c => c.outcome === 'Positivo').length;
    const pendingCalls = calls.filter(c => c.outcome === 'Da Richiamare').length;
    const conversionRate = totalCalls > 0 ? ((positiveCalls / totalCalls) * 100).toFixed(0) : 0;

    if (loading) return <div className="p-10 text-center"><Loader2 className="animate-spin mx-auto text-[#9a0002]"/></div>;

