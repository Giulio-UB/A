            if(currentAudit.propAcc) text += `• Accumulo: ${currentAudit.propAcc} kWh\n`;
            if(currentAudit.propTerm) text += `• Termico: ${currentAudit.propTerm}\n`;
            if(currentAudit.pitch) text += `• Pitch: ${currentAudit.pitch}\n`;
        }

        if(currentAudit.linkDrive) text += `\n*📁 LINK CARTELLA DRIVE*\n${currentAudit.linkDrive}\n`;

        // Codifica per URL
        const encodedText = encodeURIComponent(text);
        // Utilizzo API nativa WhatsApp (apre App su Mac o WhatsApp Web)
        const whatsappUrl = `https://api.whatsapp.com/send?text=${encodedText}`;
        
        window.open(whatsappUrl, '_blank');
    };

    return (
        <div className="h-full flex flex-col animate-in fade-in duration-300 relative">
            
            {/* SISTEMA DI DIALOG (ALERT/CONFIRM) */}
            {dialog && (
                <div className="fixed inset-0 bg-black/50 z-[100] flex items-center justify-center p-4 backdrop-blur-sm">
                    <div className="bg-white rounded-xl p-6 max-w-sm w-full shadow-2xl animate-in fade-in zoom-in duration-200">
                        <h3 className="font-bold text-lg mb-2 text-slate-800">{dialog.title}</h3>
                        <p className="text-slate-600 mb-6">{dialog.message}</p>
                        <div className="flex justify-end gap-3">
                            {dialog.type === 'confirm' && (
                                <button onClick={dialog.onCancel} className="px-4 py-2 rounded-lg font-medium text-slate-600 hover:bg-slate-100 transition">Chiudi</button>
                            )}
                            <button onClick={dialog.onConfirm} className="px-4 py-2 rounded-lg font-bold bg-[#9a0002] text-white hover:bg-[#7a0001] transition shadow-sm">
                                {dialog.type === 'confirm' ? 'Vai in Pipeline' : 'OK'}
                            </button>
                        </div>
                    </div>
                </div>
            )}

            {/* VISTA LISTA (AGGIORNATA CON LAYOUT BADGE BOLLETTE) */}
            {mode === 'list' && (
                <>
                    <div className="flex justify-between items-center mb-6">
                        <h2 className="text-2xl font-extrabold text-slate-800 flex items-center gap-2"><LayoutGrid size={24} className="text-[#9a0002]"/> Audit Manager</h2>
                        <button onClick={() => { setCurrentAudit(initialAuditState); setMode('new'); }} className="bg-[#9a0002] text-white px-5 py-2.5 rounded-xl font-bold hover:bg-[#7a0001] flex items-center gap-2 shadow-md transition"><Plus size={18}/> Nuovo Audit</button>
                    </div>
                    <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 pb-10">
                        {audits.map(a => (
                            <div key={a.id} 
                                 onClick={() => { setCurrentAudit(a); setActiveTab(a.tipoCliente || 'Azienda'); setMode('new'); }}
                                 className="bg-white p-5 rounded-2xl shadow-sm border border-slate-200 flex flex-col group hover:shadow-md transition relative overflow-hidden cursor-pointer"
                            >
                                {/* Bordo Superiore Colorato */}
                                <div className={`absolute left-0 top-0 right-0 h-1.5 ${a.tipoCliente === 'Azienda' ? 'bg-blue-600' : a.tipoCliente === 'Residenziale' ? 'bg-emerald-600' : 'bg-orange-500'}`}></div>
                                
