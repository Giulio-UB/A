        spA3Docce: '', spA3Mq: '', spA3Emis: '', spA3Elem: '', spA4Docce: '', spA4Mq: '', spA4Emis: '', spA4Elem: '',
        spArb1Docce: '', spArb1Mq: '', spArb1Emis: '', spArb1Elem: '', spArb2Docce: '', spArb2Mq: '', spArb2Emis: '', spArb2Elem: '',
        utentiDie: '', orariUtilizzo: '', nFari: '', potenzaFaro: '',
        p1f1: '', p1f2: '', p1f3: '', p2f1: '', p2f2: '', p2f3: '', p3f1: '', p3f2: '', p3f3: '',
        gas1: '', gas2: '', noteProduttive: '', linkDoc1: '', linkDoc2: '', linkDoc3: '', linkDoc4: '',
        tipoTetto: '', ombreggianti: '', mqTetto: '', orientamento: '', potenzaContatore: '',
        u1Imp: '', u1Vol: '', u1Emis: '', u1Elem: '', u1Kw: '',
        u2Imp: '', u2Vol: '', u2Emis: '', u2Elem: '', u2Kw: '',
        u3Imp: '', u3Vol: '', u3Emis: '', u3Elem: '', u3Kw: '',
        localeTermico1: '', localeTermico2: '', accumuloLocale1: '', accumuloLocale2: '',
        accumulo: 'No', detAccumulo: '', noteTecniche: '',
        chkFoto: false, chkLuce: false, chkGas: false, chkLeasing: false, chkIncentivi: false, chkPlanimetria: false,
        noteBudget: '', linkDrive: '', linkEarth: '', noteGenerali: '',
        propFv: '', propAcc: '', propTerm: '', noteDim: '', painPoints: '', pitch: '',
        statoAudit: 'Da Presentare', dataPresentazione: '', dataRichiamo: '', probabilitaChiusura: '', feedbackCliente: ''
    };
    const [currentAudit, setCurrentAudit] = useState(initialAuditState);

    useEffect(() => {
        if (initialMode) setMode(initialMode);
    }, [initialMode]);

    useEffect(() => {
        if (!user) return;
        return onSnapshot(collection(db, 'artifacts', appId, 'users', user.uid, 'audits'), (snap) => {
            const data = snap.docs.map(d => ({id: d.id, ...d.data()}));
            data.sort((a,b) => new Date(b.dataRilievo||0).getTime() - new Date(a.dataRilievo||0).getTime());
            setAudits(data);
        });
    }, [user, appId]);

    const handleSave = async () => {
        if(!currentAudit.nomeSocieta) { alert("Inserisci il Nome Società o Cliente"); return; }
        const payload = { ...currentAudit, tipoCliente: activeTab };
        
        if (currentAudit.id) { await updateDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'audits', currentAudit.id), payload); } 
        else { await addDoc(collection(db, 'artifacts', appId, 'users', user.uid, 'audits'), { ...payload, createdAt: new Date().toISOString() }); }
        
        setMode('list'); setCurrentAudit(initialAuditState);
        if(setActiveModule) setActiveModule('audits');
    };

    const deleteAudit = async (id) => await deleteDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'audits', id));

    // --- NUOVA FUNZIONE: GENERA LEAD DA AUDIT ---
    const handleGenerateLead = async () => {
        if (!currentAudit.nomeSocieta) {
            setDialog({ title: "Attenzione", message: "Inserisci almeno il Nome Società o Cliente prima di generare il Lead.", type: 'alert', onConfirm: () => setDialog(null) });
            return;
        }

        try {
            // Strutturiamo i dati per la Pipeline
            const leadData = {
                company: currentAudit.nomeSocieta,
                name: currentAudit.referente || currentAudit.presidente || '',
                phone: currentAudit.telReferente || currentAudit.telPresidente || currentAudit.telSocieta || '',
                email: currentAudit.email || currentAudit.emailPresidente || '',
                type: activeTab,
                stage: 'Da Contattare', // Stadio iniziale
                expectedValue: currentAudit.propFv ? (parseFloat(currentAudit.propFv) * 1500).toString() : '', // Stima base se c'è FV
                notes: `[Generato da Audit]\nObiettivo: ${currentAudit.obiettivo || 'N/D'}\nProposta: FV ${currentAudit.propFv || 'N/D'}kW - Acc ${currentAudit.propAcc || 'N/D'}kWh - ${currentAudit.propTerm || ''}`,
                createdAt: new Date().toISOString()
            };

            // Salviamo in Firestore nella collection 'leads'
            await addDoc(collection(db, 'artifacts', appId, 'users', user.uid, 'leads'), leadData);

            // Conferma e redirezione
            setDialog({
                title: "Lead Creato con Successo!",
                message: "Opportunità commerciale trasferita automaticamente nella Pipeline.",
                type: 'confirm',
                onConfirm: () => {
                    setDialog(null);
                    if(setActiveModule) setActiveModule('pipeline'); // Salta alla pipeline
                },
                onCancel: () => setDialog(null)
            });

        } catch (error) {
            console.error(error);
            setDialog({ title: "Errore", message: "Impossibile generare il Lead.", type: 'alert', onConfirm: () => setDialog(null) });
        }
    };

    // MOTORI DI CALCOLO DINAMICI
    const calcRowTot = (f1, f2, f3) => (Number(f1)||0) + (Number(f2)||0) + (Number(f3)||0);
    const totElec = calcRowTot(currentAudit.p1f1, currentAudit.p1f2, currentAudit.p1f3) + calcRowTot(currentAudit.p2f1, currentAudit.p2f2, currentAudit.p2f3) + calcRowTot(currentAudit.p3f1, currentAudit.p3f2, currentAudit.p3f3);
    const totGas = (Number(currentAudit.gas1)||0) + (Number(currentAudit.gas2)||0);
    const totVol = (Number(currentAudit.u1Vol)||0) + (Number(currentAudit.u2Vol)||0) + (Number(currentAudit.u3Vol)||0);
    const totElem = (Number(currentAudit.u1Elem)||0) + (Number(currentAudit.u2Elem)||0) + (Number(currentAudit.u3Elem)||0);
    const totKw = (Number(currentAudit.u1Kw)||0) + (Number(currentAudit.u2Kw)||0) + (Number(currentAudit.u3Kw)||0);

    const calcGridTot = (prefix, count, field) => Array.from({length: count}, (_, i) => i + 1).reduce((acc, i) => acc + (Number(currentAudit[`${prefix}${i}${field}`]) || 0), 0);
    const totDocceAtleti = calcGridTot('spA', 9, 'Docce');
    const totMqAtleti = calcGridTot('spA', 9, 'Mq');
    const totElemAtleti = calcGridTot('spA', 9, 'Elem');
    const totDocceArbitri = calcGridTot('spArb', 3, 'Docce');
    const totMqArbitri = calcGridTot('spArb', 3, 'Mq');
    const totElemArbitri = calcGridTot('spArb', 3, 'Elem');

    const kwFari = ((Number(currentAudit.nFari)||0) * (Number(currentAudit.potenzaFaro)||0)) / 1000;

    const getStatusStyle = (status) => {
        switch(status) {
            case 'Vinto': return 'bg-emerald-100 text-emerald-800 border-emerald-200';
            case 'Perso': return 'bg-red-100 text-red-800 border-red-200';
            case 'Presentato': return 'bg-blue-100 text-blue-800 border-blue-200';
            case 'In Valutazione': return 'bg-yellow-100 text-yellow-800 border-yellow-200';
            case 'Revisione': return 'bg-orange-100 text-orange-800 border-orange-200';
            default: return 'bg-slate-100 text-slate-800 border-slate-200';
        }
    };

    // --- NUOVA FUNZIONE: CONDIVISIONE WHATSAPP ---
    const handleShareWhatsApp = () => {
        if (!currentAudit.nomeSocieta) {
            setDialog({ title: "Attenzione", message: "Inserisci almeno il Nome Società o Cliente per generare il report.", type: 'alert', onConfirm: () => setDialog(null) });
            return;
        }

        const typeLabel = activeTab.toUpperCase();
        let text = `*REPORT RILIEVO ${typeLabel}* 📋\n`;
        text += `*Cliente:* ${currentAudit.nomeSocieta}\n`;
        
        if(currentAudit.pIva || currentAudit.cf) {
            text += `P.IVA: ${currentAudit.pIva||'-'} | C.F.: ${currentAudit.cf||'-'}\n`;
        }
        if(currentAudit.indirizzo) text += `📍 ${currentAudit.indirizzo}\n`;
        text += `📅 ${currentAudit.dataRilievo ? currentAudit.dataRilievo.split('-').reverse().join('/') : 'N/D'}\n\n`;

        text += `*📋 ANAGRAFICA*\n`;
        if(currentAudit.titoloPossesso) text += `Titolo: ${currentAudit.titoloPossesso}\n`;
        if(currentAudit.obiettivo) text += `Obiettivo: ${currentAudit.obiettivo}\n`;
        
        const refName = currentAudit.referente || currentAudit.presidente;
        const refPhone = currentAudit.telReferente || currentAudit.telPresidente;
        if(refName || refPhone) text += `Referente: ${refName || 'N/D'} ${refPhone ? '- ' + refPhone : ''}\n`;
        if(currentAudit.noteAnagrafica) text += `Note: ${currentAudit.noteAnagrafica}\n`;
        text += `\n`;

        text += `*⚡ CONSUMI & DATI TECNICI*\n`;
        text += `• Consumo Elettrico: ${totElec.toLocaleString('it-IT')} kWh/a\n`;
        text += `• Consumo Gas: ${totGas.toLocaleString('it-IT')} Smc/a\n`;
        if(currentAudit.mqTetto) text += `• Superficie Tetto: ${currentAudit.mqTetto} mq\n`;
        if(currentAudit.potenzaContatore) text += `• Contatore Attuale: ${currentAudit.potenzaContatore} kW\n`;
        
        if(activeTab === 'ASD') {
            text += `• Totale Docce: ${totDocceAtleti + totDocceArbitri}\n`;
            if(currentAudit.bollitoreIdeale) text += `• Stima Bollitore: ${currentAudit.bollitoreIdeale} Litri\n`;
        }

        if(currentAudit.propFv || currentAudit.propAcc || currentAudit.propTerm) {
            text += `\n*🎯 PROPOSTA DIMENSIONAMENTO*\n`;
