                    </div>
                    <div className="md:col-span-4">
                        <label className="block text-xs font-bold text-slate-500 mb-1.5 uppercase tracking-wide">Note Commerciali</label>
                        <input type="text" value={newCall.notes} onChange={e => setNewCall({...newCall, notes: e.target.value})} placeholder="Argomenti trattati, obiezioni..." className="w-full p-2.5 bg-white border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#9a0002] outline-none transition text-slate-700" />
