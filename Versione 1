                    <div className="md:col-span-1 flex items-end h-full pt-6">
                        <button onClick={handleSaveCall} disabled={isSaving || !newCall.contactName} className="w-full bg-[#9a0002] text-white p-2.5 rounded-lg font-bold shadow-md hover:bg-[#7a0001] transition flex justify-center items-center disabled:opacity-50 h-[46px]">{isSaving ? <Loader2 size={18} className="animate-spin" /> : <Save size={18}/>}</button>
                    </div>
                </div>
            </div>

            <div className="bg-white rounded-xl shadow-sm border border-slate-200 flex-1 flex flex-col overflow-hidden">
                <div className="p-4 border-b border-slate-200 flex justify-between items-center bg-slate-50">
                    <h3 className="font-bold text-slate-800">Storico Chiamate</h3>
                    <div className="relative w-64">
                        <Search className="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400" size={16} />
                        <input type="text" placeholder="Filtra cronologia..." value={searchTerm} onChange={e => setSearchTerm(e.target.value)} className="w-full pl-9 pr-3 py-1.5 bg-white border border-slate-300 rounded-lg text-sm focus:ring-1 focus:ring-[#9a0002] outline-none" />
                    </div>
                </div>
                <div className="flex-1 overflow-y-auto custom-scrollbar p-4 space-y-3">
                    {filteredCalls.length === 0 ? (
                        <div className="text-center py-10 text-slate-500 border-2 border-dashed border-slate-200 rounded-xl"><PhoneCall size={32} className="mx-auto mb-3 text-slate-300" /><p>Nessuna chiamata registrata.</p></div>
                    ) : (
                        filteredCalls.map(call => (
                            <div key={call.id} className="flex flex-col md:flex-row md:items-center justify-between p-4 bg-white border border-slate-200 rounded-xl shadow-sm hover:shadow-md transition gap-4 group">
                                <div className="flex items-start md:items-center gap-4 flex-1 min-w-0">
                                    <div className={`p-2.5 rounded-lg border flex-shrink-0 ${getOutcomeStyle(call.outcome)}`}>{call.outcome === 'Da Richiamare' ? <PhoneForwarded size={18}/> : <PhoneCall size={18}/>}</div>
                                    <div className="flex-1 min-w-0">
                                        <div className="flex flex-col md:flex-row md:items-center gap-2 md:gap-4 mb-1">
                                            <h4 className="font-extrabold text-slate-800 text-[15px] truncate">{call.contactName}</h4>
                                            <span className={`text-[10px] font-bold px-2 py-0.5 rounded border uppercase tracking-wider w-max ${getOutcomeStyle(call.outcome)}`}>{call.outcome}</span>
                                        </div>
                                        <p className="text-xs text-slate-500 truncate" title={call.notes}>{call.notes || 'Nessuna nota registrata.'}</p>
                                    </div>
                                </div>
                                <div className="flex items-center gap-4 flex-shrink-0 border-t md:border-t-0 md:border-l border-slate-100 pt-3 md:pt-0 md:pl-4 mt-1 md:mt-0 justify-between md:justify-end w-full md:w-auto">
                                    <span className="text-[11px] font-bold text-slate-400 flex items-center gap-1.5"><Calendar size={14}/> {call.date ? call.date.split('-').reverse().join('/') : '-'}</span>
                                    <button onClick={() => handleDeleteCall(call.id, call.contactName)} className="p-2 text-slate-300 hover:text-red-600 hover:bg-red-50 rounded-lg transition border border-transparent hover:border-red-100" title="Elimina Registro"><Trash2 size={16}/></button>
                                </div>
                            </div>
                        ))
                    )}
                </div>
            </div>
        </div>
    );
}

// --- 4. MODULO AUDIT MANAGER ---
function AuditManager({ user, appId, initialMode, setActiveModule }) {
