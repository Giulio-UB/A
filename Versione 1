function NotesModule({ user, appId }) {
    const [notes, setNotes] = useState([]);
    const [currentNote, setCurrentNote] = useState({ title: '', content: '', category: 'Normativa' });
    const [isSaving, setIsSaving] = useState(false);
    const [editingId, setEditingId] = useState(null);

    const categories = ['Normativa', 'Commerciale', 'Tecnico', 'Clienti', 'Incentivi', 'Task', 'Generico'];

    useEffect(() => {
        if (!user) return;
        return onSnapshot(collection(db, 'artifacts', appId, 'users', user.uid, 'notes'), (snap) => {
            const data = snap.docs.map(d => ({id: d.id, ...d.data()}));
            data.sort((a,b) => new Date(b.createdAt||0).getTime() - new Date(a.createdAt||0).getTime());
            setNotes(data);
        });
    }, [user, appId]);

    const handleSave = async () => {
        if (!currentNote.content) return;
        setIsSaving(true);
        try {
            if(editingId) {
                await updateDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'notes', editingId), { 
                    title: currentNote.title, 
                    content: currentNote.content, 
                    category: currentNote.category 
                });
            } else {
                await addDoc(collection(db, 'artifacts', appId, 'users', user.uid, 'notes'), { 
                    ...currentNote, 
                    createdAt: new Date().toISOString() 
                });
            }
            setCurrentNote({ title: '', content: '', category: 'Normativa' });
            setEditingId(null);
        } catch(e) { console.error(e); } finally { setIsSaving(false); }
    };

    const deleteNote = async (id) => await deleteDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'notes', id));
    
    const handleEdit = (n) => {
        setCurrentNote({ title: n.title || '', content: n.content || '', category: n.category || 'Normativa' });
        setEditingId(n.id);
        window.scrollTo({ top: 0, behavior: 'smooth' });
    };

    const handleCancelEdit = () => {
        setCurrentNote({ title: '', content: '', category: 'Normativa' });
        setEditingId(null);
    };

    return (
        <div className="h-full flex flex-col space-y-6 animate-in fade-in duration-300 max-w-[1600px] mx-auto">
            
            <div className="flex items-center gap-3 mb-2">
                <div className="bg-yellow-50 text-yellow-600 p-2.5 rounded-xl border border-yellow-200 shadow-sm"><FileText size={24} /></div>
                <h2 className="text-2xl font-extrabold text-slate-800 tracking-tight">Knowledge Base & Appunti</h2>
            </div>

            <div className="bg-white p-4 rounded-xl shadow-sm border border-slate-200 flex flex-col md:flex-row items-center gap-4 transition-all">
                <div className="w-full md:w-64 flex-shrink-0">
                    <input type="text" placeholder="Titolo nota..." value={currentNote.title} onChange={e => setCurrentNote({...currentNote, title: e.target.value})} className="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-orange-400 outline-none text-sm text-slate-800 font-bold transition" />
                </div>
                <div className="w-full md:flex-1">
                    <input type="text" placeholder="Scrivi il tuo appunto qui..." value={currentNote.content} onChange={e => setCurrentNote({...currentNote, content: e.target.value})} onKeyPress={e => e.key === 'Enter' && currentNote.content && handleSave()} className="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-orange-400 outline-none text-sm text-slate-800 transition" />
                </div>
                <div className="w-full md:w-48 flex-shrink-0">
                    <select value={currentNote.category} onChange={e => setCurrentNote({...currentNote, category: e.target.value})} className="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-orange-400 outline-none text-sm text-slate-700 cursor-pointer font-medium transition">
                        {categories.map(c => <option key={c} value={c}>{c}</option>)}
                    </select>
                </div>
                <div className="w-full md:w-auto flex gap-2">
                    {editingId && (<button onClick={handleCancelEdit} className="px-5 py-2.5 rounded-lg text-sm font-bold text-slate-600 bg-slate-100 hover:bg-slate-200 transition shadow-sm border border-slate-200">Annulla</button>)}
                    <button onClick={handleSave} disabled={!currentNote.content || isSaving} className="w-full md:w-auto px-8 py-2.5 bg-[#d97706] hover:bg-[#b45309] text-white rounded-lg text-sm font-bold shadow-md transition disabled:opacity-50 flex items-center justify-center gap-2">
                        {isSaving ? <Loader2 size={16} className="animate-spin"/> : (editingId ? 'Aggiorna' : 'Salva')}
                    </button>
                </div>
            </div>

            <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 pb-10 flex-1 content-start overflow-y-auto custom-scrollbar">
                {notes.map(n => {
                    const catStyle = getNoteCategoryStyle(n.category);
                    return (
                    <div key={n.id} className="bg-[#fffdf0] rounded-2xl p-5 shadow-sm border border-slate-200 relative group flex flex-col min-h-[160px] hover:shadow-md transition-all">
                        <div className={`absolute top-0 left-0 w-full h-1.5 rounded-t-2xl ${catStyle.border}`}></div>
                        <div className="flex justify-between items-start mb-3 mt-1">
                            <div className="flex flex-col pr-8 min-w-0">
                                <h4 className="font-extrabold text-slate-800 text-[15px] truncate" title={n.title}>{n.title || 'Appunto Veloce'}</h4>
                                <span className={`text-[9px] font-black uppercase tracking-wider w-max px-1.5 py-0.5 rounded mt-1.5 border shadow-sm ${catStyle.badge}`}>
                                    {n.category || 'Generico'}
                                </span>
                            </div>
                            <div className="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity absolute top-4 right-3 bg-[#fffdf0] pl-2 rounded-lg">
                                <button onClick={() => handleEdit(n)} className="text-blue-600 hover:bg-blue-50 p-1.5 rounded-md transition border border-transparent hover:border-blue-200 shadow-sm" title="Modifica"><Edit size={14}/></button>
                                <button onClick={() => deleteNote(n.id)} className="text-red-500 hover:bg-red-50 p-1.5 rounded-md transition border border-transparent hover:border-red-200 shadow-sm" title="Elimina"><Trash2 size={14}/></button>
                            </div>
                        </div>
                        <p className="text-[13px] text-slate-700 flex-1 whitespace-pre-wrap leading-relaxed">{n.content}</p>
                        <div className="mt-4 pt-3 border-t border-slate-200/70">
                            <span className="text-[10px] font-bold text-slate-400 uppercase tracking-wider flex items-center gap-1.5"><Calendar size={12}/> {n.createdAt ? new Date(n.createdAt).toLocaleDateString('it-IT') : ''}</span>
                        </div>
                    </div>
                )})}
                {notes.length === 0 && (
                    <div className="col-span-full p-12 text-center text-slate-500 border-2 border-dashed border-slate-300 rounded-2xl bg-white shadow-sm">
                        <FileText size={40} className="mx-auto mb-4 text-slate-300"/>
                        <p className="text-lg font-bold text-slate-700">La tua Knowledge Base è vuota.</p>
                    </div>
                )}
            </div>
        </div>
    );
}

